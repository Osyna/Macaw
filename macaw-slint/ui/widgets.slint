// Hand-rolled controls — no std-widgets: smaller binary, one visual language,
// every color from Theme.pal so the whole app re-skins live.

import { Theme, Tip } from "theme.slint";

// Labeled settings row: hover shows the hint through the global Tip overlay.
export component Row inherits HorizontalLayout {
    in property <string> label;
    in property <string> hint: "";
    spacing: 12px;
    height: 34px;
    preferred-height: 34px;
    lbl := Rectangle {
        width: 150px;
        Text {
            x: 0;
            width: parent.width;
            text: root.label;
            color: ta.has-hover && root.hint != "" ? Theme.pal.accent : Theme.pal.fg;
            font-size: 13px;
            vertical-alignment: center;
            height: 100%;
            overflow: elide;
        }
        // subtle dotted-ish underline while hovered (hint available)
        if ta.has-hover && root.hint != "": Rectangle {
            y: parent.height / 2 + 9px;
            height: 1px;
            width: min(parent.width, 140px);
            background: Theme.pal.muted;
        }
        ta := TouchArea {
            enabled: root.hint != "";
            changed has-hover => {
                if (self.has-hover) {
                    Tip.text = root.hint;
                    Tip.x = lbl.absolute-position.x;
                    Tip.y = lbl.absolute-position.y + lbl.height + 2px;
                } else if (Tip.text == root.hint) {
                    Tip.text = "";
                }
            }
        }
    }
    @children
}

export component Btn inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked;

    height: 30px;
    width: label.preferred-width + 24px;
    border-radius: Theme.radius;
    background: !root.enabled ? Theme.pal.control
        : touch.pressed ? (root.primary ? Theme.pal.accent.darker(15%) : Theme.pal.control.darker(8%))
        : root.danger ? (touch.has-hover ? Theme.pal.danger : Theme.pal.control)
        : root.primary ? Theme.pal.accent
        : touch.has-hover ? Theme.pal.control.darker(4%) : Theme.pal.control;
    border-width: 1px;
    border-color: root.primary ? transparent : Theme.pal.border;

    label := Text {
        text: root.text;
        color: !root.enabled ? Theme.pal.muted
            : root.primary ? Theme.pal.accent-fg
            : root.danger && touch.has-hover ? white
            : root.danger ? Theme.pal.danger : Theme.pal.fg;
        font-size: 13px;
        font-weight: 600;
    }
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
    }
}

export component Toggle inherits Rectangle {
    in-out property <bool> checked;
    in property <bool> enabled: true;
    callback toggled(bool);

    width: 40px;
    height: 22px;
    border-radius: Theme.radius;
    background: root.checked ? Theme.pal.accent : Theme.pal.border;
    animate background { duration: 120ms; }

    Rectangle {
        x: root.checked ? parent.width - self.width - 3px : 3px;
        y: 3px;
        width: 16px;
        height: 16px;
        border-radius: Theme.radius;
        background: root.checked ? Theme.pal.accent-fg : Theme.pal.fg;
        animate x { duration: 120ms; easing: ease-out; }
    }
    TouchArea {
        enabled: root.enabled;
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
        mouse-cursor: MouseCursor.pointer;
    }
}

export component SliderX inherits Rectangle {
    in-out property <float> value: 0;
    in property <float> minimum: 0;
    in property <float> maximum: 100;
    in property <float> step: 1;
    callback changed(float);

    height: 22px;
    preferred-height: 22px;
    min-width: 110px;
    preferred-width: 150px;
    max-width: 220px;
    horizontal-stretch: 0;
    clip: true;
    property <float> t: min(1.0, max(0.0, (root.value - root.minimum) / max(0.0001, root.maximum - root.minimum)));

    Rectangle { // track
        y: parent.height / 2 - 2px;
        height: 4px;
        border-radius: Theme.radius;
        background: Theme.pal.border;
    }
    Rectangle { // fill
        x: 0;
        y: parent.height / 2 - 2px;
        width: parent.width * root.t;
        height: 4px;
        border-radius: Theme.radius;
        background: Theme.pal.accent;
    }
    Rectangle { // knob
        x: (parent.width - self.width) * root.t;
        y: parent.height / 2 - 7px;
        width: 14px;
        height: 14px;
        border-radius: Theme.radius;
        background: Theme.pal.fg;
        border-width: 1px;
        border-color: Theme.pal.border;
    }
    TouchArea {
        moved => { root.set-from-x(self.mouse-x); }
        clicked => { root.set-from-x(self.mouse-x); }
        mouse-cursor: MouseCursor.pointer;
    }
    function set-from-x(mx: length) {
        root.value = min(root.maximum, max(root.minimum,
            root.minimum + (root.maximum - root.minimum) * (mx / root.width)));
        root.value = round(root.value / root.step) * root.step;
        root.changed(root.value);
    }
}

// Dropdown: options popup drawn with PopupWindow.
export component Select inherits Rectangle {
    in property <[string]> options;
    in-out property <int> current: 0;
    callback changed(int);

    height: 30px;
    min-width: 140px;
    border-radius: Theme.radius;
    background: Theme.pal.control;
    border-width: 1px;
    border-color: Theme.pal.border;
    clip: true;

    Text {
        x: 10px;
        width: parent.width - 34px; // keep clear of the ▾ arrow
        text: root.current >= 0 && root.current < root.options.length ? root.options[root.current] : "";
        color: Theme.pal.fg;
        font-size: 13px;
        vertical-alignment: center;
        height: 100%;
        overflow: elide;
    }
    Text {
        x: parent.width - 20px;
        text: "▾";
        color: Theme.pal.muted;
        font-size: 11px;
        vertical-alignment: center;
        height: 100%;
    }
    TouchArea {
        clicked => { pop.show(); }
        mouse-cursor: MouseCursor.pointer;
    }
    pop := PopupWindow {
        x: 0;
        y: root.height + 2px;
        width: root.width;
        Rectangle {
            background: Theme.pal.surface;
            border-radius: Theme.radius;
            border-width: 1px;
            border-color: Theme.pal.border;
            VerticalLayout {
                padding: 4px;
                for opt[i] in root.options: Rectangle {
                    height: 26px;
                    border-radius: Theme.radius;
                    background: ta.has-hover ? Theme.pal.control : transparent;
                    Text {
                        x: 8px;
                        text: opt;
                        color: i == root.current ? Theme.pal.accent : Theme.pal.fg;
                        font-size: 13px;
                        vertical-alignment: center;
                        height: 100%;
                    }
                    ta := TouchArea {
                        clicked => {
                            root.current = i;
                            root.changed(i);
                        }
                        mouse-cursor: MouseCursor.pointer;
                    }
                }
            }
        }
    }
}

export component Field inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;
    in property <bool> secret: false;
    callback edited(string);
    callback submitted(string);

    height: 30px;
    min-width: 120px;
    border-radius: Theme.radius;
    background: Theme.pal.control;
    border-width: 1px;
    border-color: input.has-focus ? Theme.pal.accent : Theme.pal.border;

    input := TextInput {
        x: 10px;
        width: parent.width - 20px;
        height: 100%;
        vertical-alignment: center;
        text <=> root.text;
        color: Theme.pal.fg;
        font-size: 13px;
        single-line: true;
        input-type: root.secret ? InputType.password : InputType.text;
        edited => { root.edited(self.text); }
        accepted => { root.submitted(self.text); }
    }
    if root.text == "" && !input.has-focus: Text {
        x: 10px;
        text: root.placeholder;
        color: Theme.pal.muted;
        font-size: 13px;
        vertical-alignment: center;
        height: 100%;
    }
}

export component Badge inherits Rectangle {
    in property <string> text;
    in property <color> tint: Theme.pal.muted;
    height: 18px;
    width: t.preferred-width + 12px;
    border-radius: Theme.radius;
    background: root.tint.with-alpha(0.14);
    t := Text {
        text: root.text;
        color: root.tint;
        font-size: 10px;
        font-weight: 700;
    }
}

export component ProgressBar inherits Rectangle {
    // pct < 0 => indeterminate sweep
    in property <float> pct: -1;
    height: 6px;
    border-radius: Theme.radius;
    background: Theme.pal.border;
    clip: true;

    if root.pct >= 0: Rectangle {
        x: 0;
        width: parent.width * min(1.0, root.pct / 100);
        height: 100%;
        border-radius: Theme.radius;
        background: Theme.pal.accent;
        animate width { duration: 150ms; }
    }
    if root.pct < 0: Rectangle {
        property <float> t: Math.mod(animation-tick() / 1.2s, 1.0);
        x: parent.width * (self.t * 1.4 - 0.4);
        width: parent.width * 0.4;
        height: 100%;
        border-radius: Theme.radius;
        background: Theme.pal.accent;
    }
}

export component SectionTitle inherits Text {
    color: Theme.pal.muted;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
}

export component Card inherits Rectangle {
    in property <string> title;
    border-radius: Theme.radius;
    background: Theme.pal.surface;
    border-width: 1px;
    border-color: Theme.pal.border;
    VerticalLayout {
        padding: 18px;
        spacing: 6px;
        SectionTitle { text: root.title; }
        @children
    }
}

// Flickable with a visible scrollbar — the "you can scroll" indicator.
// Thumb tracks viewport-y, drags, and only appears when content overflows.
export component ScrollArea inherits Rectangle {
    in-out property <length> viewport-height <=> flick.viewport-height;
    in-out property <length> viewport-y <=> flick.viewport-y;
    // bind content width to this: the bar gets a reserved gutter, so it
    // never draws over content
    out property <length> content-width: flick.width;

    property <bool> scrollable: flick.viewport-height > self.height + 1px;
    property <length> track-h: self.height - 8px;
    property <length> thumb-h: max(28px, self.track-h * self.height / max(1px, flick.viewport-height));
    property <float> progress: flick.viewport-height > self.height
        ? -flick.viewport-y / (flick.viewport-height - self.height) : 0;

    flick := Flickable {
        x: 0;
        // gutter is ALWAYS reserved: making it conditional on `scrollable`
        // creates a layout feedback loop (bar -> narrower -> taller -> bar)
        width: root.width - 12px;
        height: 100%;
        @children
    }

    if root.scrollable: Rectangle {
        x: parent.width - 9px;
        y: 4px;
        width: 6px;
        height: root.track-h;
        border-radius: 3px;
        background: Theme.pal.control; // follows the app theme (dark/light)
        thumb := Rectangle {
            x: 0;
            y: root.progress * (root.track-h - root.thumb-h);
            width: 6px;
            height: root.thumb-h;
            border-radius: 3px;
            background: bar-ta.has-hover || bar-ta.pressed ? Theme.pal.accent : Theme.pal.muted;
        }
        bar-ta := TouchArea {
            moved => {
                if (self.pressed) {
                    flick.viewport-y = -clamp(
                        (self.mouse-y - root.thumb-h / 2) / max(1px, root.track-h - root.thumb-h),
                        0, 1) * (flick.viewport-height - root.height);
                }
            }
            clicked => {
                flick.viewport-y = -clamp(
                    (self.mouse-y - root.thumb-h / 2) / max(1px, root.track-h - root.thumb-h),
                    0, 1) * (flick.viewport-height - root.height);
            }
            mouse-cursor: MouseCursor.pointer;
        }
    }
}

// Multi-line text editor (system-prompt box). Scrolls when the text overflows
// the fixed height; placeholder shows while empty and unfocused.
export component MultiField inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;
    callback edited(string);

    min-height: 96px;
    border-radius: Theme.radius;
    background: Theme.pal.control;
    border-width: 1px;
    border-color: input.has-focus ? Theme.pal.accent : Theme.pal.border;
    clip: true;

    Flickable {
        x: 10px;
        y: 8px;
        width: parent.width - 20px;
        height: parent.height - 16px;
        viewport-height: max(self.height, input.preferred-height);
        input := TextInput {
            width: parent.width;
            text <=> root.text;
            color: Theme.pal.fg;
            font-size: 13px;
            single-line: false;
            wrap: word-wrap;
            edited => { root.edited(self.text); }
        }
    }
    if root.text == "" && !input.has-focus: Text {
        x: 10px;
        y: 8px;
        width: parent.width - 20px;
        text: root.placeholder;
        color: Theme.pal.muted;
        font-size: 13px;
        wrap: word-wrap;
    }
}
