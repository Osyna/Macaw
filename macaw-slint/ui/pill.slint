// The recording pill — faithful port of the original canvas renderer
// (ui/src/overlay.ts / the PyQt window.py before it), plus selectable
// transcribing animations. Used by the real overlay (layer-shell process +
// winit fallback) AND the settings live preview.
//
// Bar layout (overlay.ts:356-372): side padding clears the rounded ends,
// auto gap = slot*0.58, auto width fills the slot, overflow rescales.
// EQ look (overlay.ts:381-397): color = idle→gradient blend by `heard`,
// gradient sampled with SMOOTH interpolation, alpha fades continuously
// with the bar level — a real fade, not a threshold.

export component OverlayPill inherits Rectangle {
    in property <string> mode: "eq"; // eq | loader | done | error
    in property <string> record-anim: "bars"; // eq: bars | mirror | dots | orb
    in property <string> anim: "waves"; // loader: waves | sweep | pulse | dots | scan | cascade | shimmer
    in property <string> done-anim: "pop"; // done entrance: pop | flash | rise | none
    in property <bool> demo-loop: false; // gallery tiles: replay entrances on a timer
    in property <float> anim-speed: 1.0;
    in property <[float]> levels;
    in property <float> heard: 0; // 0..1 — idle→lit color blend (eq mode)
    in property <[color]> loader-colors: [#E5322B, #F7B500, #2F6FD0];
    in property <string> error-text: "";
    in property <color> pill-bg: #171310;
    in property <float> pill-opacity: 0.94;
    in property <color> idle-color: #E7D8C4;
    in property <[color]> eq-colors: [#E5322B, #F7B500, #2F6FD0];
    in property <color> ok-color: #2E9E6B;
    in property <color> danger-color: #C81F1A;
    in property <length> r-tl: 18px;
    in property <length> r-tr: 18px;
    in property <length> r-br: 18px;
    in property <length> r-bl: 3px;
    in property <length> pill-border-width: 0px;
    in property <color> pill-border-color: transparent;
    in property <float> bar-width: -1;   // px, -1 = auto
    in property <float> bar-spacing: -1; // px, -1 = auto
    in property <length> bar-radius: 0px;
    in property <bool> bar-fade: true;

    // ── shared bar layout (overlay.ts barLayout) ─────────────────────
    property <int> n: max(1, levels.length);
    property <length> hpad: min(max(max(r-tl, r-tr), max(r-br, r-bl)), self.width * 0.4);
    property <length> avail: max(1px, self.width - 2 * hpad);
    property <length> slot: avail / n;
    property <length> gap: bar-spacing < 0 ? slot * 0.58 : bar-spacing * 1px;
    property <length> bw0: max(2px, bar-width < 0 ? slot - gap : bar-width * 1px);
    property <length> pitch0: bw0 + gap;
    property <float> fit: pitch0 * n - gap > avail ? avail / (pitch0 * n - gap) : 1.0;
    property <length> bw: bw0 * fit;
    property <length> pitch: pitch0 * fit;
    property <length> row-w: pitch * n - (pitch - bw);
    property <length> start: hpad + (avail - row-w) / 2;
    property <length> br: min(max(0px, bar-radius), bw / 2);

    // smooth palette sampling (overlay.ts paletteAt)
    // clamped segment index + intra-segment position (t is measured from the
    // CLAMPED index so frac=1 lands exactly on the last stop — using mod()
    // here glitched the tail to the second-to-last color)
    pure function pal-i(frac: float) -> int {
        return min(eq-colors.length - 2, floor(clamp(frac, 0, 1) * (eq-colors.length - 1)));
    }
    pure function pal-t(frac: float) -> float {
        return clamp(clamp(frac, 0, 1) * (eq-colors.length - 1) - pal-i(frac), 0, 1);
    }
    pure function pal(frac: float) -> color {
        if (eq-colors.length == 0) {
            return idle-color;
        }
        if (eq-colors.length == 1) {
            return eq-colors[0];
        }
        return eq-colors[pal-i(frac)].mix(eq-colors[pal-i(frac) + 1], 1 - pal-t(frac));
    }

    property <float> t: animation-tick() / 1s * 4.8 * max(0.25, anim-speed);

    // loader palette: per-state stops (Rust resolves link-to-recording)
    pure function lpal-i(frac: float) -> int {
        return min(loader-colors.length - 2, floor(clamp(frac, 0, 1) * (loader-colors.length - 1)));
    }
    pure function lpal(frac: float) -> color {
        if (loader-colors.length == 0) {
            return pal(frac);
        }
        if (loader-colors.length == 1) {
            return loader-colors[0];
        }
        return loader-colors[lpal-i(frac)].mix(
            loader-colors[lpal-i(frac) + 1],
            1 - clamp(clamp(frac, 0, 1) * (loader-colors.length - 1) - lpal-i(frac), 0, 1));
    }

    background: root.mode == "error" ? root.danger-color.with-alpha(root.pill-opacity)
                                     : root.pill-bg.with-alpha(root.pill-opacity);
    border-top-left-radius: root.r-tl;
    border-top-right-radius: root.r-tr;
    border-bottom-right-radius: root.r-br;
    border-bottom-left-radius: root.r-bl;
    border-width: root.pill-border-width;
    border-color: root.pill-border-color;
    animate background { duration: 160ms; }
    clip: true;

    // ── recording: audio-reactive, selectable ────────────────────────
    // bars (classic): bottom-anchored, real fade
    if root.mode == "eq" && (root.record-anim == "bars" || root.record-anim == "mirror"): Rectangle {
        property <length> vpad: max(8px, root.height * 0.18);
        property <length> maxh: root.height - 2 * self.vpad;
        property <bool> mirror: root.record-anim == "mirror";
        for lvl[i] in root.levels: Rectangle {
            property <float> frac: root.n > 1 ? i / (root.n - 1) : 0;
            x: root.start + i * root.pitch;
            width: root.bw;
            y: parent.mirror
                ? (root.height - self.height) / 2
                : root.height - parent.vpad - self.height;
            height: max(2px, min(1.0, lvl) * parent.maxh);
            border-radius: root.br;
            background: root.idle-color
                .mix(root.pal(self.frac), 1 - root.heard)
                .with-alpha(root.bar-fade ? (100 + 155 * min(1.0, lvl)) / 255 : 1.0);
        }
    }
    // dots: one dot per bar, size + glow follow the level
    if root.mode == "eq" && root.record-anim == "dots": Rectangle {
        for lvl[i] in root.levels: Rectangle {
            property <float> frac: root.n > 1 ? i / (root.n - 1) : 0;
            property <length> d: 3px + min(1.0, lvl) * min(root.pitch - 1px, root.height * 0.24);
            x: root.start + i * root.pitch + (root.bw - self.d) / 2;
            y: (root.height - self.d) / 2;
            width: self.d;
            height: self.d;
            border-radius: self.d / 2;
            background: root.idle-color
                .mix(root.pal(self.frac), 1 - root.heard)
                .with-alpha(root.bar-fade ? (100 + 155 * min(1.0, lvl)) / 255 : 1.0);
        }
    }
    // orb: one breathing sphere driven by the smoothed energy
    if root.mode == "eq" && root.record-anim == "orb": Rectangle {
        property <length> d: root.height * (0.28 + 0.5 * root.heard);
        x: (root.width - self.d) / 2;
        y: (root.height - self.d) / 2;
        width: self.d;
        height: self.d;
        border-radius: self.d / 2;
        background: root.idle-color.mix(root.pal(0.5), 1 - root.heard);
        // halo ring
        Rectangle {
            x: -6px;
            y: -6px;
            width: parent.width + 12px;
            height: parent.height + 12px;
            border-radius: self.width / 2;
            border-width: 2px;
            border-color: root.pal(0.5).with-alpha(0.25 + 0.45 * root.heard);
        }
    }
    // wave: oscilloscope — bars ride a traveling sine, swing scales with level
    if root.mode == "eq" && root.record-anim == "wave": Rectangle {
        for lvl[i] in root.levels: Rectangle {
            property <float> frac: root.n > 1 ? i / (root.n - 1) : 0;
            x: root.start + i * root.pitch;
            width: root.bw;
            height: max(3px, root.height * 0.10 + min(1.0, lvl) * root.height * 0.14);
            y: (root.height - self.height) / 2
                + sin((root.t * 1.5 - i * 0.6) * 1rad) * root.height * 0.26 * min(1.0, lvl);
            border-radius: root.br;
            background: root.idle-color
                .mix(root.pal(self.frac), 1 - root.heard)
                .with-alpha(root.bar-fade ? (100 + 155 * min(1.0, lvl)) / 255 : 1.0);
        }
    }
    // blocks: segmented VU columns — discrete cells light with the level
    if root.mode == "eq" && root.record-anim == "blocks": blocks-root := Rectangle {
        property <length> vpad: max(8px, root.height * 0.18);
        property <length> maxh: root.height - 2 * self.vpad;
        property <length> cell: (self.maxh - 4 * 2px) / 5;
        for lvl[i] in root.levels: Rectangle {
            property <float> frac: root.n > 1 ? i / (root.n - 1) : 0;
            property <float> lv: min(1.0, lvl);
            x: root.start + i * root.pitch;
            y: parent.vpad;
            width: root.bw;
            height: parent.maxh;
            for s in 5: Rectangle {
                x: 0;
                y: parent.height - (s + 1) * blocks-root.cell - s * 2px;
                width: parent.width;
                height: blocks-root.cell;
                border-radius: min(root.br, self.height / 2);
                background: root.idle-color
                    .mix(root.pal(parent.frac), 1 - root.heard)
                    .with-alpha(parent.lv * 5 > s ? 1.0 : 0.12);
            }
        }
    }
    // ripple: rings expand from the center, intensity follows the energy
    if root.mode == "eq" && root.record-anim == "ripple": Rectangle {
        // resting core
        Rectangle {
            property <length> d: root.height * 0.16;
            x: (root.width - self.d) / 2;
            y: (root.height - self.d) / 2;
            width: self.d;
            height: self.d;
            border-radius: self.d / 2;
            background: root.idle-color.mix(root.pal(0.5), 1 - root.heard);
        }
        for r in 3: Rectangle {
            property <float> ph: Math.mod(root.t * 0.22 + r / 3.0, 1.0);
            property <length> d: self.ph * min(root.width * 0.55, root.height * 1.8);
            x: (root.width - self.d) / 2;
            y: (root.height - self.d) / 2;
            width: self.d;
            height: self.d;
            border-radius: self.d / 2;
            border-width: 2px;
            border-color: root.pal(self.ph).with-alpha((1 - self.ph) * (0.2 + 0.8 * root.heard));
        }
    }
    // meter: one horizontal level bar, VU style
    if root.mode == "eq" && root.record-anim == "meter": Rectangle {
        property <length> mh: max(6px, root.height * 0.22);
        Rectangle { // track
            x: root.hpad;
            y: (root.height - parent.mh) / 2;
            width: root.width - 2 * root.hpad;
            height: parent.mh;
            border-radius: self.height / 2;
            background: root.idle-color.with-alpha(0.18);
            Rectangle { // fill
                x: 0;
                y: 0;
                width: parent.width * clamp(root.heard, 0.02, 1.0);
                height: parent.height;
                border-radius: self.height / 2;
                background: root.pal(root.heard);
            }
        }
    }

    // ── transcribing: selectable loader ──────────────────────────────
    // bar-based loaders: waves | pulse | cascade | shimmer | heartbeat
    if root.mode == "loader" && (root.anim == "waves" || root.anim == "pulse"
        || root.anim == "cascade" || root.anim == "shimmer" || root.anim == "heartbeat"): Rectangle {
        property <length> maxh: root.height * 0.42;
        for lvl[i] in root.levels: Rectangle {
            property <float> fx: root.n > 1 ? i / (root.n - 1) : 0;
            property <float> hb: Math.mod(root.t * 0.22, 1.0);
            property <float> amp: root.anim == "pulse"
                // breathing: whole row swells together, slight center bias
                ? clamp((0.5 + 0.5 * sin(root.t * 0.6 * 1rad)) * (0.55 + 0.45 * (1 - abs(2 * self.fx - 1))), 0, 1)
                // heartbeat: lub-dub — two sharp spikes, then rest
                : root.anim == "heartbeat"
                ? clamp((Math.pow(max(0.0, sin(self.hb * 360deg)), 24)
                        + 0.6 * Math.pow(max(0.0, sin((self.hb - 0.14) * 360deg)), 24))
                        * (0.35 + 0.65 * (1 - abs(2 * self.fx - 1))), 0.04, 1)
                // cascade: a sharp pulse train travels bar to bar
                : root.anim == "cascade"
                ? Math.pow(max(0.02, sin((root.t * 0.8 - self.fx * 6.3) * 1rad)), 3)
                // shimmer: phase-scrambled twinkle, no visible direction
                : root.anim == "shimmer"
                ? clamp(0.5 + 0.5 * sin((root.t * 1.6 + 40 * sin(i * 12.9898 * 1rad)) * 1rad)
                        * sin((root.t * 0.9 + 40 * sin(i * 78.233 * 1rad)) * 1rad) * 2, 0, 1)
                // waves (classic): max(w1, 0.6*w2)
                : max(0.5 + 0.5 * sin((root.t - self.fx * 5) * 1rad),
                      0.6 * (0.5 + 0.5 * sin((root.t * 0.7 - self.fx * 8) * 1rad)));
            x: root.start + i * root.pitch;
            width: root.bw;
            y: (root.height - self.height) / 2;
            height: 3px + self.amp * parent.maxh;
            border-radius: root.br;
            background: root.lpal(self.fx)
                .with-alpha(root.bar-fade ? (60 + self.amp * 175) / 255 : 1.0);
        }
    }
    // sweep: sliding capsule (the v0.5 look)
    if root.mode == "loader" && root.anim == "sweep": Rectangle {
        x: (parent.width + 40px) * Math.mod(root.t / 4.8 / 1.1, 1.0) - 40px;
        y: parent.height / 2 - 2px;
        width: 40px;
        height: 4px;
        border-radius: 2px;
        background: root.lpal(0.5);
    }
    // scan: capsule ping-pongs edge to edge, trailing tint
    if root.mode == "loader" && root.anim == "scan": Rectangle {
        property <float> ph: abs(Math.mod(root.t / 4.8 * 0.9, 2.0) - 1.0);
        x: root.hpad + (parent.width - 2 * root.hpad - 46px) * self.ph;
        y: parent.height / 2 - 2px;
        width: 46px;
        height: 4px;
        border-radius: 2px;
        background: root.lpal(self.ph);
    }
    // dots: three bouncing dots
    if root.mode == "loader" && root.anim == "dots": Rectangle {
        for i in 3: Rectangle {
            property <float> ph: 0.5 + 0.5 * sin((root.t * 1.2 - i * 1.1) * 1rad);
            x: parent.width / 2 + (i - 1) * 18px - 4px;
            y: parent.height / 2 - 4px - self.ph * (parent.height * 0.18);
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: root.lpal(i / 2.0).with-alpha(0.45 + 0.55 * self.ph);
        }
    }
    // orbit: two dots circle each other
    if root.mode == "loader" && root.anim == "orbit": Rectangle {
        for i in 2: Rectangle {
            property <angle> ang: root.t * 0.5 * 1rad + i * 180deg;
            x: parent.width / 2 + cos(self.ang) * min(parent.width * 0.28, 56px) - 4px;
            y: parent.height / 2 + sin(self.ang) * parent.height * 0.2 - 4px;
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: root.lpal(i == 0 ? 0.15 : 0.85);
        }
    }
    // typewriter: bars print left to right, then the line resets
    if root.mode == "loader" && root.anim == "typewriter": Rectangle {
        property <float> fill: Math.mod(root.t * 0.14, 1.18);
        for lvl[i] in root.levels: Rectangle {
            property <float> fx: root.n > 1 ? i / (root.n - 1) : 0;
            x: root.start + i * root.pitch;
            width: root.bw;
            height: root.height * 0.24;
            y: (root.height - self.height) / 2;
            border-radius: root.br;
            background: root.lpal(self.fx)
                .with-alpha(self.fx <= parent.fill ? 1.0 : 0.12);
        }
    }
    // bounce: one ball crosses while bouncing
    if root.mode == "loader" && root.anim == "bounce": Rectangle {
        property <float> px: abs(Math.mod(root.t / 4.8 * 0.7, 2.0) - 1.0);
        x: root.hpad + (parent.width - 2 * root.hpad - 10px) * self.px;
        y: parent.height * 0.62 - abs(sin(root.t * 1.6 * 1rad)) * parent.height * 0.32 - 5px;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        background: root.lpal(self.px);
    }

    // ── done: check mark with a selectable entrance ──────────────────
    if root.mode == "done": done-root := Rectangle {
        // demo-loop (gallery tiles): the entrance replays on a timer instead
        // of firing once at instantiation
        property <bool> in-anim: root.demo-loop && Math.mod(animation-tick() / 1s, 2.2) > 0.5;
        init => {
            if (!root.demo-loop) {
                self.in-anim = true;
            }
        }
        // flash: ok-tinted wash fades away
        if root.done-anim == "flash": Rectangle {
            width: 100%;
            height: 100%;
            background: root.ok-color;
            opacity: done-root.in-anim ? 0 : 0.55;
            animate opacity { duration: 550ms; easing: ease-out; }
        }
        // rise: the bar row surges up once in the ok color
        if root.done-anim == "rise": Rectangle {
            property <length> vpad: max(8px, root.height * 0.18);
            for lvl[i] in root.levels: Rectangle {
                property <float> fx: root.n > 1 ? i / (root.n - 1) : 0;
                x: root.start + i * root.pitch;
                width: root.bw;
                y: root.height - parent.vpad - self.height;
                height: done-root.in-anim ? max(3px, (0.25 + 0.75 * (1 - abs(2 * self.fx - 1))) * (root.height - 2 * parent.vpad)) : 3px;
                border-radius: root.br;
                background: root.ok-color;
                opacity: done-root.in-anim ? 0 : 0.9;
                animate height { duration: 300ms; easing: ease-out; }
                animate opacity { duration: 700ms; easing: ease-in; }
            }
        }
        Text {
            text: "✓";
            color: root.done-anim == "flash" && !parent.in-anim ? root.pill-bg : root.ok-color;
            font-size: root.done-anim == "pop" ? (parent.in-anim ? 20px : 4px)
                : 20px;
            opacity: root.done-anim == "none" ? 1.0 : (parent.in-anim ? 1.0 : 0);
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: 100%;
            height: 100%;
            animate font-size { duration: 320ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
            animate opacity { duration: 260ms; easing: ease-out; }
        }
    }

    // ── error: reason ────────────────────────────────────────────────
    if root.mode == "error": Text {
        text: root.error-text == "" ? "Error" : root.error-text;
        color: white;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
        overflow: elide;
    }
}
