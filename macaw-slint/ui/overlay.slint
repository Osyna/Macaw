// Recording overlay window: a frameless, transparent shell around the pill.
// Geometry/placement is the shell's job (layer-shell process on Wayland,
// window rules on Hyprland, floating fallback elsewhere) — this window is
// only the winit fallback host; the pill itself lives in pill.slint.

import { OverlayPill } from "pill.slint";

export component OverlayWindow inherits Window {
    in property <string> mode <=> pill.mode;
    in property <[float]> levels <=> pill.levels;
    in property <string> error-text <=> pill.error-text;

    in property <color> pill-bg <=> pill.pill-bg;
    in property <float> pill-opacity <=> pill.pill-opacity;
    in property <color> idle-color <=> pill.idle-color;
    in property <[color]> eq-colors <=> pill.eq-colors;
    in property <color> ok-color <=> pill.ok-color;
    in property <color> danger-color <=> pill.danger-color;
    in property <length> r-tl <=> pill.r-tl;
    in property <length> r-tr <=> pill.r-tr;
    in property <length> r-br <=> pill.r-br;
    in property <length> r-bl <=> pill.r-bl;
    in property <length> pill-border-width <=> pill.pill-border-width;
    in property <color> pill-border-color <=> pill.pill-border-color;
    in property <length> bar-width <=> pill.bar-width;
    in property <length> bar-spacing <=> pill.bar-spacing;
    in property <length> bar-radius <=> pill.bar-radius;
    in property <bool> bar-fade <=> pill.bar-fade;

    title: "macaw-overlay";
    no-frame: true;
    always-on-top: true;
    background: transparent;

    pill := OverlayPill {
        width: 100%;
        height: 100%;
    }
}
