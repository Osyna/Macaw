// Recording overlay: a frameless pill with a 24-bar equalizer.
//
// Rust drives everything through OverlayWindow's properties:
//   mode    "eq" | "loader" | "done" | "error"
//   levels  24 smoothed 0..1 floats (attack smoothing happens in Rust)
// Geometry/colors arrive pre-resolved (theme + config overrides merged) so
// this file contains zero policy — it just draws.

import { Theme } from "theme.slint";

export component OverlayWindow inherits Window {
    in property <string> mode: "eq";
    in property <[float]> levels;
    in property <string> error-text: "";

    // resolved look (Rust merges theme + config)
    in property <color> pill-bg: #171310;
    in property <float> pill-opacity: 0.94;
    in property <color> idle-color: #3A3A3A;
    in property <[color]> eq-colors: [#E5322B, #F7B500, #2F6FD0];
    in property <color> ok-color: #2E9E6B;
    in property <color> danger-color: #CC4444;
    in property <length> r-tl: 18px;
    in property <length> r-tr: 18px;
    in property <length> r-br: 18px;
    in property <length> r-bl: 3px;
    in property <length> pill-border-width: 0px;
    in property <color> pill-border-color: transparent;
    in property <int> bar-count: 24;
    in property <length> bar-width: 4px;
    in property <length> bar-spacing: 3px;
    in property <length> bar-radius: 0px;
    in property <bool> bar-fade: true;

    title: "macaw-overlay";
    no-frame: true;
    always-on-top: true;
    background: transparent;

    property <float> sweep: Math.mod(animation-tick() / 1.1s, 1.0);

    pill := Rectangle {
        width: 100%;
        height: 100%;
        background: root.mode == "error" ? root.danger-color.with-alpha(root.pill-opacity)
                                         : root.pill-bg.with-alpha(root.pill-opacity);
        border-top-left-radius: root.r-tl;
        border-top-right-radius: root.r-tr;
        border-bottom-right-radius: root.r-br;
        border-bottom-left-radius: root.r-bl;
        border-width: root.pill-border-width;
        border-color: root.pill-border-color;
        animate background { duration: 160ms; }
        clip: true;

        // ── equalizer ────────────────────────────────────────────────
        if root.mode == "eq": HorizontalLayout {
            alignment: center;
            spacing: root.bar-spacing;
            padding-top: 8px;
            padding-bottom: 8px;
            for lvl[i] in root.levels: Rectangle {
                // slot: stretched by the layout; the bar centers inside it
                width: root.bar-width;
                background: transparent;
                property <float> t: root.levels.length > 1 ? i / (root.levels.length - 1) : 0;
                property <color> lit: root.eq-colors.length == 0 ? root.idle-color
                    : root.eq-colors[min(root.eq-colors.length - 1, floor(self.t * root.eq-colors.length))];
                Rectangle {
                    y: (parent.height - self.height) / 2;
                    width: 100%;
                    height: max(4px, parent.height * min(1.0, lvl));
                    border-radius: root.bar-radius;
                    background: lvl < 0.06 && root.bar-fade
                        ? parent.lit.with-alpha(0.35)
                        : (lvl < 0.06 ? root.idle-color : parent.lit);
                }
            }
        }

        // ── transcribing: sweeping loader dot trail ─────────────────
        if root.mode == "loader": Rectangle {
            x: (parent.width + 40px) * root.sweep - 40px;
            y: parent.height / 2 - 2px;
            width: 40px;
            height: 4px;
            border-radius: 2px;
            background: root.eq-colors.length > 0 ? root.eq-colors[0] : white;
        }

        // ── done: check mark ────────────────────────────────────────
        if root.mode == "done": Text {
            text: "✓";
            color: root.ok-color;
            font-size: 20px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: 100%;
            height: 100%;
        }

        // ── error: reason ───────────────────────────────────────────
        if root.mode == "error": Text {
            text: root.error-text == "" ? "Error" : root.error-text;
            color: white;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: 100%;
            height: 100%;
            overflow: elide;
        }
    }
}
