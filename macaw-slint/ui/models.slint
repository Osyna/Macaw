// Model manager, PyQt-style master-detail: a compact list on the left
// (search + status filters), one permanently-visible dossier on the right —
// description, pros & cons, spec table, provenance links, per-model language
// and backend parameters, plus the actions and live progress.

import { Theme } from "theme.slint";
import { Btn, Badge, ProgressBar, SectionTitle, Toggle, SliderX, Select, Field, ScrollArea } from "widgets.slint";

export struct ModelRow {
    id: string,
    label: string,
    backend: string,
    size: string,
    speed: string,
    languages: string,
    hardware: string,
    vram: string,
    streaming: bool,
    cloud: bool,
    recommended: bool,
    rating: int,
    pros: string,
    cons: string,
    notes: string,
    available: bool,     // dependency (extra) installed
    installed: bool,     // weights on disk
    ready: bool,         // can transcribe right now
    active: bool,
    extra: string,       // pip extra, "" = in base deps
    disk-size: string,   // human, "" if none
    api-key-set: bool,
    min-specs: string,
    rec-specs: string,
    source-url: string,
    repo-url: string,
    lang-select: bool,
    has-params: bool,
    expanded: bool,      // = selected (dossier shown on the right)
    busy: bool,
    progress-pct: float, // -1 = indeterminate
    progress-msg: string,
}

export struct ParamRow {
    key: string,
    label: string,
    kind: string,        // int | float | bool
    hint: string,
    value: float,
    bvalue: bool,
    minimum: float,
    maximum: float,
    step: float,
}

component Stars inherits HorizontalLayout {
    in property <int> rating; // 0..5
    spacing: 1px;
    for i in 5: Text {
        text: i < root.rating ? "★" : "☆";
        color: i < root.rating ? Theme.pal.warn : Theme.pal.border;
        font-size: 12px;
    }
}

component KV inherits HorizontalLayout {
    in property <string> k;
    in property <string> v;
    spacing: 10px;
    height: 22px;
    Text {
        text: root.k;
        color: Theme.pal.muted;
        font-size: 12px;
        width: 110px;
        vertical-alignment: center;
    }
    Text {
        text: root.v;
        color: Theme.pal.fg;
        font-size: 12px;
        vertical-alignment: center;
        overflow: elide;
        horizontal-stretch: 1;
        wrap: word-wrap;
    }
}

component FilterChip inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked;
    width: t.preferred-width + 16px;
    height: 26px;
    border-radius: Theme.radius;
    background: root.active ? Theme.pal.accent : Theme.pal.control;
    border-width: 1px;
    border-color: root.active ? transparent : Theme.pal.border;
    t := Text {
        text: root.text;
        color: root.active ? Theme.pal.accent-fg : Theme.pal.fg;
        font-size: 11px;
        font-weight: 600;
    }
    TouchArea {
        clicked => { root.clicked(); }
        mouse-cursor: MouseCursor.pointer;
    }
}

// compact list entry
component ModelItem inherits Rectangle {
    in property <ModelRow> m;
    callback select(string);
    height: inner.preferred-height + 20px;
    background: m.expanded ? Theme.pal.control : (ta.has-hover ? Theme.pal.control.with-alpha(0.5) : transparent);
    border-width: m.expanded ? 1px : 0px;
    border-color: m.active ? Theme.pal.accent : Theme.pal.border;

    inner := VerticalLayout {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
        spacing: 3px;
        HorizontalLayout {
            spacing: 6px;
            Rectangle { // status dot: ready green / installed amber / none gray
                y: parent.height / 2 - 4px;
                width: 8px;
                height: 8px;
                background: m.active ? Theme.pal.accent
                    : m.ready ? Theme.pal.ok
                    : m.installed ? Theme.pal.warn : Theme.pal.border;
            }
            Text {
                text: m.label;
                color: Theme.pal.fg;
                font-size: 13px;
                font-weight: m.expanded ? 700 : 500;
                overflow: elide;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }
        }
        HorizontalLayout {
            spacing: 5px;
            alignment: start;
            Badge { text: m.backend; }
            if m.cloud: Badge { text: "cloud"; tint: Theme.pal.warn; }
            if m.streaming: Badge { text: "stream"; tint: Theme.pal.accent; }
            Text {
                text: m.size;
                color: Theme.pal.muted;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
    ta := TouchArea {
        clicked => { root.select(m.id); }
        mouse-cursor: MouseCursor.pointer;
    }
}

export component ModelsView inherits HorizontalLayout {
    in property <[ModelRow]> models;
    in property <ModelRow> sel; // the selected model (Rust keeps it in sync)
    in property <bool> have-sel: false;
    in property <bool> op-running;
    in property <[ParamRow]> detail-params;
    in property <[string]> langs;
    in property <int> lang-current;
    in-out property <int> filter-current: 0;

    callback install(string);
    callback download(string);
    callback activate(string);
    callback delete(string);
    callback cancel();
    callback toggle-expand(string); // = select
    callback open-url(string);
    callback set-lang(string, int);
    callback param-num(string, string, float);
    callback param-bool(string, string, bool);
    callback search(string);
    callback filter(int);

    spacing: 0px;

    // ── left: search / filters / list ────────────────────────────────
    Rectangle {
        width: 300px;
        background: Theme.pal.bg;
        VerticalLayout {
            padding: 12px;
            spacing: 8px;
            Field {
                placeholder: "Search…";
                edited(t) => { root.search(t); }
            }
            HorizontalLayout {
                spacing: 4px;
                alignment: start;
                for f[i] in ["All", "Ready", "Local", "Cloud", "Live"]: FilterChip {
                    text: f;
                    active: root.filter-current == i;
                    clicked => {
                        root.filter-current = i;
                        root.filter(i);
                    }
                }
            }
            ScrollArea {
                viewport-height: list.preferred-height;
                list := VerticalLayout {
                    alignment: start;
                    spacing: 4px;
                    for m in root.models: ModelItem {
                        m: m;
                        select(id) => { root.toggle-expand(id); }
                    }
                    if root.models.length == 0: Text {
                        text: "No models match.";
                        color: Theme.pal.muted;
                        font-size: 12px;
                    }
                }
            }
        }
    }
    Rectangle { width: 1px; background: Theme.pal.border; }

    // ── right: dossier ───────────────────────────────────────────────
    ScrollArea {
        horizontal-stretch: 1;
        viewport-height: detail.preferred-height;
        detail := VerticalLayout {
            padding: 18px;
            alignment: start;
            spacing: 10px;

            if !root.have-sel: Text {
                text: "Select a model on the left.";
                color: Theme.pal.muted;
                font-size: 13px;
            }

            if root.have-sel: HorizontalLayout {
                spacing: 10px;
                Text {
                    text: sel.label;
                    color: Theme.pal.fg;
                    font-size: 18px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
                Stars { rating: sel.rating; }
                Rectangle { horizontal-stretch: 1; }
                if sel.active: Badge { text: "ACTIVE"; tint: Theme.pal.accent; }
                if sel.recommended && !sel.active: Badge { text: "RECOMMENDED"; tint: Theme.pal.ok; }
                if sel.cloud: Badge { text: "CLOUD"; tint: Theme.pal.warn; }
                if sel.streaming: Badge { text: "STREAMING"; tint: Theme.pal.accent; }
                if !sel.cloud && !sel.streaming: Badge { text: "OFFLINE"; }
            }

            // actions right under the title — always reachable
            if root.have-sel && sel.busy: VerticalLayout {
                spacing: 4px;
                ProgressBar { pct: sel.progress-pct; }
                HorizontalLayout {
                    Text {
                        text: sel.progress-msg;
                        color: Theme.pal.muted;
                        font-size: 11px;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }
                    Btn { text: "Cancel"; clicked => { root.cancel(); } }
                }
            }
            if root.have-sel && !sel.busy: HorizontalLayout {
                spacing: 8px;
                alignment: start;
                if !sel.available && sel.extra != "": Btn {
                    text: "Install \{sel.extra} deps";
                    primary: true;
                    enabled: !root.op-running;
                    clicked => { root.install(sel.extra); }
                }
                if sel.available && !sel.ready && !sel.cloud: Btn {
                    text: "Download";
                    primary: true;
                    enabled: !root.op-running;
                    clicked => { root.download(sel.id); }
                }
                if sel.cloud && !sel.api-key-set: Text {
                    text: "Set your OpenAI API key in Settings";
                    color: Theme.pal.warn;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                if sel.ready && !sel.active: Btn {
                    text: "Set active";
                    primary: true;
                    enabled: !root.op-running;
                    clicked => { root.activate(sel.id); }
                }
                if sel.installed: Btn {
                    text: "Delete";
                    danger: true;
                    enabled: !root.op-running;
                    clicked => { root.delete(sel.id); }
                }
            }

            if root.have-sel && sel.notes != "": Text {
                text: sel.notes;
                color: Theme.pal.fg;
                font-size: 12px;
                wrap: word-wrap;
            }
            if root.have-sel && sel.pros != "": Text {
                text: "+ \{sel.pros}";
                color: Theme.pal.ok;
                font-size: 12px;
                wrap: word-wrap;
            }
            if root.have-sel && sel.cons != "": Text {
                text: "− \{sel.cons}";
                color: Theme.pal.warn;
                font-size: 12px;
                wrap: word-wrap;
            }

            if root.have-sel: VerticalLayout {
                spacing: 2px;
                SectionTitle { text: "SPECS"; }
                KV { k: "Engine"; v: sel.backend; }
                KV { k: "Download"; v: sel.size; }
                KV { k: "Speed"; v: sel.speed; }
                KV { k: "Languages"; v: sel.languages; }
                KV { k: "Hardware"; v: sel.hardware; }
                if sel.min-specs != "": KV { k: "Minimal"; v: sel.min-specs; }
                if sel.rec-specs != "": KV { k: "Recommended"; v: sel.rec-specs; }
                if sel.vram != "-" && sel.vram != "": KV { k: "VRAM"; v: sel.vram; }
                if sel.disk-size != "": KV { k: "On disk"; v: sel.disk-size; }
            }

            if root.have-sel && (sel.source-url != "" || sel.repo-url != ""): HorizontalLayout {
                spacing: 8px;
                alignment: start;
                if sel.source-url != "": Btn {
                    text: "Library ↗";
                    clicked => { root.open-url(sel.source-url); }
                }
                if sel.repo-url != "": Btn {
                    text: "Weights ↗";
                    clicked => { root.open-url(sel.repo-url); }
                }
            }

            if root.have-sel && sel.lang-select: HorizontalLayout {
                spacing: 10px;
                height: 34px;
                Text {
                    text: "Spoken language";
                    color: Theme.pal.fg;
                    font-size: 13px;
                    width: 140px;
                    vertical-alignment: center;
                }
                Select {
                    options: root.langs;
                    current: root.lang-current;
                    changed(i) => { root.set-lang(sel.id, i); }
                }
            }

            if root.have-sel && sel.has-params: VerticalLayout {
                spacing: 4px;
                SectionTitle { text: "PARAMETERS"; }
                for p in root.detail-params: VerticalLayout {
                    spacing: 2px;
                    HorizontalLayout {
                        spacing: 10px;
                        height: 30px;
                        Text {
                            text: p.label;
                            color: Theme.pal.fg;
                            font-size: 13px;
                            width: 140px;
                            vertical-alignment: center;
                        }
                        if p.kind == "bool": Toggle {
                            checked: p.bvalue;
                            toggled(v) => { root.param-bool(sel.id, p.key, v); }
                        }
                        if p.kind != "bool": SliderX {
                            value: p.value;
                            minimum: p.minimum;
                            maximum: p.maximum;
                            step: p.step;
                            changed(v) => { root.param-num(sel.id, p.key, v); }
                        }
                        if p.kind != "bool": Text {
                            text: p.kind == "int" ? "\{Math.round(p.value)}" : "\{Math.round(p.value * 100) / 100}";
                            color: Theme.pal.muted;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                    if p.hint != "": Text {
                        text: p.hint;
                        color: Theme.pal.muted;
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
