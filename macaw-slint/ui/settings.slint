// Settings: every control writes one config field through a typed callback;
// Rust turns it into a `config.set {patch}` RPC. The engine's `config` event
// echoes back and re-fills `cfg`, so the UI never holds its own truth.
//
// Appearance/theming lives in its own tab (appearance.slint) — this view is
// audio, hotkey, cloud and system only, as two columns of cards.

import { Theme } from "theme.slint";
import { Btn, Toggle, SliderX, Select, Field, Row, Card, ScrollArea } from "widgets.slint";

export struct Cfg {
    language: string,
    output-mode: string,       // clipboard | type | live
    device-label: string,
    silence-timeout: float,
    auto-stop: bool,
    vad-gate: bool,
    level-gain: float,
    silence-level: float,
    sound-enabled: bool,
    onboarded: bool,
    punctuation-hints: bool,
    hotkey-enabled: bool,
    hotkey: string,
    theme: string,
    theme-dirty: bool,
    theme-is-custom: bool,
    theme-custom-name: string,
    app-theme: string,
    window-position: string,
    overlay-opacity: float,
    overlay-width: float,
    overlay-height: float,
    overlay-x: string,
    overlay-y: string,
    corner-radius: float,
    corner-link: bool,
    c-tl: float,
    c-tr: float,
    c-br: float,
    c-bl: float,
    bar-spacing: float,
    bar-width: float,
    bar-radius: float,
    bar-fade: bool,
    bar-count: float,
    record-anim: string,
    transcribe-anim: string,
    done-anim: string,
    anim-speed: float,
    trans-link: bool,
    done-color: string,
    done-value: color,
    done-ring: string,
    done-ring-value: color,
    error-color: string,
    error-value: color,
    overlay-bg: string,
    overlay-bg-value: color,
    eq-colors: string,         // comma-joined hex
    accent-color: string,
    accent-value: color,
    border-color: string,
    border-value: color,
    border-width: float,
    api-key-set: bool,
    proxy: string,
    ssl-verify: bool,
    autostart: bool,
    llm-enabled: bool,
    llm-prompt: string,
    llm-base-url: string,
}

export component SettingsView inherits ScrollArea {
    in property <Cfg> cfg;
    in property <[string]> devices;      // labels; [0] = "System default"
    in-out property <int> device-current: 0;
    in property <[string]> langs;        // display names; index-paired with codes in Rust
    in property <int> lang-current: 0;
    in property <bool> capturing-hotkey: false;
    in property <bool> live-native: false; // active model streams natively

    callback set-str(string, string);    // key, value
    callback set-num(string, float);
    callback set-bool(string, bool);
    callback pick-device(int);
    callback capture-hotkey();
    callback set-autostart(bool);
    callback manage-providers();
    callback pick-default-lang(int);
    in property <float> mic-level: 0;    // live input level (Settings-visible)
    in property <bool> engine-connected: false;
    in property <string> engine-state: "idle";
    callback restart-engine();
    callback reload-model();

    viewport-height: cols.preferred-height;

    cols := HorizontalLayout {
        width: root.content-width;
        padding: 16px;
        spacing: 14px;

        // ── left column: audio / hotkey ──────────────────────────────
        VerticalLayout {
            width: (root.content-width - 46px) * 0.5;
            alignment: start;
            spacing: 14px;

            Card {
                title: "RECORDING";
                Row {
                    label: "Microphone";
                    hint: "Input device for recording. System default follows your desktop's choice.";
                    Select {
                        options: root.devices;
                        current <=> root.device-current;
                        changed(i) => { root.pick-device(i); }
                    }
                }
                Row {
                    label: "Input level";
                    hint: "Live mic check AND the silence gate in one: drag the marker — anything quieter counts as silence for the auto-stop timer. The zone left of the marker is the silent band.";
                    meter := Rectangle {
                        horizontal-stretch: 1;
                        property <float> drag-val: -1; // -1 = not dragging
                        property <float> thr: self.drag-val >= 0 ? self.drag-val : clamp(cfg.silence-level, 0, 1);
                        Rectangle { // track
                            y: parent.height / 2 - 5px;
                            width: parent.width;
                            height: 10px;
                            border-radius: 5px;
                            background: Theme.pal.control;
                            clip: true;
                            Rectangle { // silence zone: everything left of the marker
                                x: 0;
                                y: 0;
                                width: parent.width * meter.thr;
                                height: parent.height;
                                background: Theme.pal.danger.with-alpha(0.12);
                            }
                            Rectangle { // live fill
                                x: 0;
                                y: 0;
                                width: parent.width * clamp(root.mic-level, 0, 1);
                                height: parent.height;
                                border-radius: 5px;
                                // muted while under the silence gate, alive above it
                                background: root.mic-level < meter.thr ? Theme.pal.muted
                                    : root.mic-level > 0.45 + meter.thr * 0.5 ? Theme.pal.ok : Theme.pal.accent;
                                animate width { duration: 60ms; }
                            }
                        }
                        thumb := Rectangle { // draggable threshold marker
                            x: parent.width * meter.thr - self.width / 2;
                            y: parent.height / 2 - 9px;
                            width: 6px;
                            height: 18px;
                            border-radius: 3px;
                            background: ta.pressed || ta.has-hover ? Theme.pal.accent : Theme.pal.fg;
                            border-width: 1px;
                            border-color: Theme.pal.bg;
                        }
                        ta := TouchArea {
                            // whole track: press anywhere to set, drag to adjust,
                            // release commits once
                            mouse-cursor: MouseCursor.col-resize;
                            pointer-event(ev) => {
                                if (ev.kind == PointerEventKind.down) {
                                    meter.drag-val = clamp(self.mouse-x / self.width, 0, 1);
                                }
                                if (ev.kind == PointerEventKind.up && meter.drag-val >= 0) {
                                    root.set-num("silence_level", meter.drag-val);
                                    meter.drag-val = -1;
                                }
                            }
                            moved => {
                                if (self.pressed) {
                                    meter.drag-val = clamp(self.mouse-x / self.width, 0, 1);
                                }
                            }
                        }
                    }
                    Text {
                        text: "\{round(meter.thr * 100)}%";
                        color: Theme.pal.muted;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
                Row {
                    label: "Input boost";
                    hint: "Amplifies the meter and the pill animation for quiet microphones — visual only, and loud peaks still cap at the maximum.";
                    SliderX {
                        value: cfg.level-gain;
                        minimum: 0.5;
                        maximum: 4.0;
                        step: 0.25;
                        changed(v) => { root.set-num("level_gain", v); }
                    }
                    Text { text: "\{cfg.level-gain}×"; color: Theme.pal.muted; font-size: 12px; vertical-alignment: center; }
                }
                Row {
                    label: "Stop after silence";
                    hint: "Recording stops by itself after this much silence (live typing defaults to 5 s).";
                    if cfg.auto-stop: SliderX {
                        value: cfg.silence-timeout;
                        minimum: 1;
                        maximum: 10;
                        step: 0.5;
                        changed(v) => { root.set-num("silence_timeout", v); }
                    }
                    Text {
                        text: cfg.auto-stop ? "\{cfg.silence-timeout}s" : "∞ — stops only when you toggle it";
                        color: Theme.pal.muted;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-stretch: cfg.auto-stop ? 0 : 1;
                    }
                }
                Row {
                    label: "Never auto-stop";
                    hint: "Infinite recording: the hotkey (or tray / Record button) starts AND stops it — silence never ends the session.";
                    Toggle { checked: !cfg.auto-stop; toggled(v) => { root.set-bool("auto_stop", !v); } }
                }
                Row {
                    label: "Skip silence";
                    hint: "Cuts silent stretches before transcription — faster on every model and stops silence hallucinations. Turn off only if words get clipped.";
                    Toggle { checked: cfg.vad-gate; toggled(v) => { root.set-bool("vad_gate", v); } }
                }
                Row {
                    label: "Output type";
                    hint: "Clipboard: text lands in the clipboard, paste it anywhere. Type into window: the finished text is typed into the window you recorded from. Live typing: words appear while you speak.";
                    Select {
                        options: ["Clipboard", "Type into window", "Live typing"];
                        current: cfg.output-mode == "live" ? 2 : cfg.output-mode == "type" ? 1 : 0;
                        changed(i) => { root.set-str("output_mode", i == 2 ? "live" : i == 1 ? "type" : "clipboard"); }
                    }
                }
                if cfg.output-mode == "live": Row {
                    label: "";
                    Text {
                        text: root.live-native
                            ? "⚡ This model streams natively — words appear near-instantly."
                            : "◔ This model can't stream — Macaw smart-splits at pauses so long dictations stay fast.";
                        color: root.live-native ? Theme.pal.ok : Theme.pal.muted;
                        font-size: 12px;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                    }
                }
                Row {
                    label: "Default language";
                    hint: "What models transcribe unless a model overrides it in the Model Manager. English-only models ignore this.";
                    Select {
                        options: root.langs;
                        current: root.lang-current;
                        changed(i) => { root.pick-default-lang(i); }
                    }
                }
                Row {
                    label: "Sounds";
                    hint: "Soft audio cues when recording starts, stops and text is delivered.";
                    Toggle { checked: cfg.sound-enabled; toggled(v) => { root.set-bool("sound_enabled", v); } }
                }
                Row {
                    label: "Punctuation hints";
                    hint: "Nudges the model toward proper punctuation.";
                    Toggle { checked: cfg.punctuation-hints; toggled(v) => { root.set-bool("punctuation_hints", v); } }
                }
            }

            Card {
                title: "HOTKEY";
                Row {
                    label: "Global hotkey";
                    hint: "Toggle recording from anywhere — captured at the input layer, works on Wayland and X11.";
                    Toggle { checked: cfg.hotkey-enabled; toggled(v) => { root.set-bool("hotkey_enabled", v); } }
                }
                Row {
                    label: "Combo";
                    hint: "The key combination. Click Capture, then press your keys.";
                    Text {
                        text: root.capturing-hotkey ? "press keys…" : (cfg.hotkey == "" ? "not set" : cfg.hotkey);
                        color: root.capturing-hotkey ? Theme.pal.accent : Theme.pal.muted;
                        font-size: 13px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Btn { text: "Capture"; enabled: !root.capturing-hotkey; clicked => { root.capture-hotkey(); } }
                }
            }
        }

        // ── right column: cloud / system ─────────────────────────────
        VerticalLayout {
            width: (root.content-width - 46px) * 0.5;
            alignment: start;
            spacing: 14px;

            Card {
                title: "CLOUD & PROVIDERS";
                Row {
                    label: "LLM providers";
                    hint: "Configure OpenAI, Claude, Gemini, x.ai, OpenRouter, Groq, a local Ollama server and more — API keys, endpoints and models — plus network/proxy settings. Keys are encrypted on this machine.";
                    Rectangle { horizontal-stretch: 1; }
                    Btn {
                        text: "Manage providers →";
                        primary: true;
                        clicked => { root.manage-providers(); }
                    }
                }
            }

            Card {
                title: "ENGINE";
                Row {
                    label: "Status";
                    hint: "The speech backend runs as its own process; models load inside it.";
                    Rectangle { // status dot
                        width: 8px;
                        Rectangle {
                            y: parent.height / 2 - 4px;
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: !root.engine-connected ? Theme.pal.danger
                                : root.engine-state == "error" ? Theme.pal.danger : Theme.pal.ok;
                        }
                    }
                    Text {
                        text: !root.engine-connected ? "not connected"
                            : root.engine-state == "idle" ? "running"
                            : root.engine-state;
                        color: Theme.pal.muted;
                        font-size: 13px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }
                Row {
                    label: "Reload model";
                    hint: "Unloads the speech model — its worker process is terminated, force-killed if stuck — and loads it again clean. Try this first if transcription hangs.";
                    Rectangle { horizontal-stretch: 1; }
                    Btn {
                        text: "Reload";
                        enabled: root.engine-connected;
                        clicked => { root.reload-model(); }
                    }
                }
                Row {
                    label: "Restart engine";
                    hint: "Kills the whole backend process and starts a fresh one — model, audio, everything reloads. The heavy hammer when nothing else helps.";
                    Rectangle { horizontal-stretch: 1; }
                    Btn {
                        text: "Force restart";
                        danger: true;
                        clicked => { root.restart-engine(); }
                    }
                }
            }

            Card {
                title: "SYSTEM";
                Row {
                    label: "App theme";
                    hint: "This window's chrome. The recording indicator is themed in Appearance.";
                    Select {
                        options: ["dark (terminal)", "light"];
                        current: cfg.app-theme == "light" ? 1 : 0;
                        changed(i) => { root.set-str("app_theme", i == 1 ? "light" : "dark"); }
                    }
                }
                Row {
                    label: "Start on login";
                    hint: "Adds an autostart entry so Macaw launches with your session.";
                    Toggle { checked: cfg.autostart; toggled(v) => { root.set-autostart(v); } }
                }
            }
        }
    }
}
