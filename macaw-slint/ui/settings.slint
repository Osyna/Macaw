// Settings: every control writes one config field through a typed callback;
// Rust turns it into a `config.set {patch}` RPC. The engine's `config` event
// echoes back and re-fills `cfg`, so the UI never holds its own truth.
//
// Layout is two-column (audio/system left, appearance right). The appearance
// editor is STATE-SCOPED: the preview chips select Recording / Transcribing /
// Done / Error, and the controls below swap to that state's options.

import { Theme, Look, Tip } from "theme.slint";
import { Btn, Toggle, SliderX, Select, Field, SectionTitle } from "widgets.slint";
import { OverlayPill } from "pill.slint";
import { ColorField, GradientEditor } from "picker.slint";

export struct Cfg {
    language: string,
    output-mode: string,       // clipboard | type
    device-label: string,
    silence-timeout: float,
    sound-enabled: bool,
    streaming: bool,
    punctuation-hints: bool,
    hotkey-enabled: bool,
    hotkey: string,
    theme: string,
    theme-dirty: bool,
    theme-is-custom: bool,
    theme-custom-name: string,
    app-theme: string,
    window-position: string,
    overlay-opacity: float,
    overlay-width: float,
    overlay-height: float,
    overlay-x: string,
    overlay-y: string,
    corner-radius: float,
    corner-link: bool,
    c-tl: float,
    c-tr: float,
    c-br: float,
    c-bl: float,
    bar-spacing: float,
    bar-width: float,
    bar-radius: float,
    bar-fade: bool,
    bar-count: float,
    transcribe-anim: string,
    anim-speed: float,
    trans-link: bool,
    done-color: string,
    done-value: color,
    error-color: string,
    error-value: color,
    overlay-bg: string,
    overlay-bg-value: color,
    eq-colors: string,         // comma-joined hex
    accent-color: string,
    accent-value: color,
    border-color: string,
    border-value: color,
    border-width: float,
    api-key-set: bool,
    proxy: string,
    ssl-verify: bool,
    autostart: bool,
}

component Row inherits HorizontalLayout {
    in property <string> label;
    in property <string> hint: "";
    spacing: 12px;
    height: 34px;
    preferred-height: 34px;
    lbl := Rectangle {
        width: 150px;
        Text {
            x: 0;
            width: parent.width;
            text: root.label;
            color: ta.has-hover && root.hint != "" ? Theme.pal.accent : Theme.pal.fg;
            font-size: 13px;
            vertical-alignment: center;
            height: 100%;
            overflow: elide;
        }
        // subtle dotted-ish underline while hovered (hint available)
        if ta.has-hover && root.hint != "": Rectangle {
            y: parent.height / 2 + 9px;
            height: 1px;
            width: min(parent.width, 140px);
            background: Theme.pal.muted;
        }
        ta := TouchArea {
            enabled: root.hint != "";
            changed has-hover => {
                if (self.has-hover) {
                    Tip.text = root.hint;
                    Tip.x = lbl.absolute-position.x;
                    Tip.y = lbl.absolute-position.y + lbl.height + 2px;
                } else if (Tip.text == root.hint) {
                    Tip.text = "";
                }
            }
        }
    }
    @children
}

component Card inherits Rectangle {
    in property <string> title;
    border-radius: Theme.radius;
    background: Theme.pal.surface;
    border-width: 1px;
    border-color: Theme.pal.border;
    VerticalLayout {
        padding: 18px;
        spacing: 6px;
        SectionTitle { text: root.title; }
        @children
    }
}

export component SettingsView inherits Flickable {
    in property <Cfg> cfg;
    in property <[string]> devices;      // labels; [0] = "System default"
    in-out property <int> device-current: 0;
    in property <bool> capturing-hotkey: false;

    callback set-str(string, string);    // key, value
    callback set-num(string, float);
    callback set-bool(string, bool);
    callback pick-device(int);
    callback capture-hotkey();
    callback set-autostart(bool);
    callback set-api-key(string);
    callback eq-set(int, color);
    callback eq-add();
    callback eq-remove(int);
    callback trans-set(int, color);
    callback trans-add();
    callback trans-remove(int);
    callback set-corner(int, float);   // corner index (tl,tr,br,bl), px
    callback pillbg-picked(color);
    callback pillbg-clear();
    callback done-picked(color);
    callback done-clear();
    callback error-picked(color);
    callback error-clear();
    callback pin-overlay(bool);
    callback state-picked(string);
    in-out property <bool> pin-indicator: false;
    callback accent-picked(color);
    callback accent-clear();
    callback border-picked(color);
    callback border-clear();

    callback theme-picked(int);
    callback save-theme(string);
    callback delete-theme();
    in property <[string]> theme-names;
    in-out property <int> theme-current: 0;
    in-out property <string> preview-mode: "eq";

    property <[string]> positions: ["bottom_center", "bottom_left", "bottom_right", "top_center", "top_left", "top_right", "custom"];

    viewport-height: cols.preferred-height;

    cols := HorizontalLayout {
        width: root.width;
        padding: 16px;
        spacing: 14px;

        // ── left column: audio / hotkey / cloud / system ─────────────
        VerticalLayout {
            width: (root.width - 46px) * 0.42;
            alignment: start;
            spacing: 14px;

            Card {
                title: "RECORDING";
                Row {
                    label: "Microphone";
                    hint: "Input device for recording. System default follows your desktop's choice.";
                    Select {
                        options: root.devices;
                        current <=> root.device-current;
                        changed(i) => { root.pick-device(i); }
                    }
                }
                Row {
                    label: "Stop after silence";
                    hint: "Recording stops by itself after this much silence.";
                    SliderX {
                        value: cfg.silence-timeout;
                        minimum: 1;
                        maximum: 10;
                        step: 0.5;
                        changed(v) => { root.set-num("silence_timeout", v); }
                    }
                    Text { text: "\{cfg.silence-timeout}s"; color: Theme.pal.muted; font-size: 12px; vertical-alignment: center; }
                }
                Row {
                    label: "Output";
                    hint: "Where text goes: the clipboard, or typed into the focused window.";
                    Select {
                        options: ["Clipboard", "Type into window"];
                        current: cfg.output-mode == "type" ? 1 : 0;
                        changed(i) => { root.set-str("output_mode", i == 1 ? "type" : "clipboard"); }
                    }
                }
                Row {
                    label: "Language (ISO)";
                    hint: "Default spoken language (two-letter code). Models can override it individually.";
                    Field {
                        text: cfg.language;
                        placeholder: "en";
                        submitted(v) => { root.set-str("language", v); }
                    }
                }
                Row {
                    label: "Sounds";
                    hint: "Soft audio cues when recording starts, stops and text is delivered.";
                    Toggle { checked: cfg.sound-enabled; toggled(v) => { root.set-bool("sound_enabled", v); } }
                }
                Row {
                    label: "Punctuation hints";
                    hint: "Nudges the model toward proper punctuation.";
                    Toggle { checked: cfg.punctuation-hints; toggled(v) => { root.set-bool("punctuation_hints", v); } }
                }
                Row {
                    label: "Live typing";
                    hint: "Streaming mode: words are typed while you speak (streaming-capable models only).";
                    Toggle { checked: cfg.streaming; toggled(v) => { root.set-bool("streaming", v); } }
                }
            }

            Card {
                title: "HOTKEY";
                Row {
                    label: "Global hotkey";
                    hint: "Toggle recording from anywhere — captured at the input layer, works on Wayland and X11.";
                    Toggle { checked: cfg.hotkey-enabled; toggled(v) => { root.set-bool("hotkey_enabled", v); } }
                }
                Row {
                    label: "Combo";
                    hint: "The key combination. Click Capture, then press your keys.";
                    Text {
                        text: root.capturing-hotkey ? "press keys…" : (cfg.hotkey == "" ? "not set" : cfg.hotkey);
                        color: root.capturing-hotkey ? Theme.pal.accent : Theme.pal.muted;
                        font-size: 13px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Btn { text: "Capture"; enabled: !root.capturing-hotkey; clicked => { root.capture-hotkey(); } }
                }
            }

            Card {
                title: "CLOUD & NETWORK";
                Row {
                    label: "OpenAI API key";
                    hint: "Only needed for the GPT-4o cloud models. Stored in your local config file.";
                    Field {
                        text: "";
                        secret: true;
                        placeholder: cfg.api-key-set ? "•••••••• (set)" : "sk-…";
                        submitted(v) => { root.set-api-key(v); }
                    }
                }
                Row {
                    label: "HTTP(S) proxy";
                    hint: "Route model downloads and cloud calls through a proxy.";
                    Field { text: cfg.proxy; placeholder: "http://host:port"; submitted(v) => { root.set-str("proxy", v); } }
                }
                Row {
                    label: "Verify SSL";
                    hint: "Disable only behind a corporate TLS-intercepting proxy.";
                    Toggle { checked: cfg.ssl-verify; toggled(v) => { root.set-bool("ssl_verify", v); } }
                }
            }

            Card {
                title: "SYSTEM";
                Row {
                    label: "App theme";
                    hint: "This window's chrome. The recording indicator has its own themes.";
                    Select {
                        options: ["dark (terminal)", "light"];
                        current: cfg.app-theme == "light" ? 1 : 0;
                        changed(i) => { root.set-str("app_theme", i == 1 ? "light" : "dark"); }
                    }
                }
                Row {
                    label: "Start on login";
                    hint: "Adds an autostart entry so Macaw launches with your session.";
                    Toggle { checked: cfg.autostart; toggled(v) => { root.set-autostart(v); } }
                }
            }
        }

        // ── right column: appearance (state-scoped) ──────────────────
        VerticalLayout {
            width: (root.width - 46px) * 0.58;
            alignment: start;
            spacing: 14px;

            Card {
                title: "APPEARANCE";

                // live preview
                Rectangle {
                    height: max(Look.pv-h + 32px, 90px);
                    border-radius: Theme.radius;
                    background: @linear-gradient(135deg, #3B4252 0%, #2E3440 50%, #242933 100%);
                    clip: true;
                    OverlayPill {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: min(Look.pv-w, parent.width - 24px);
                        height: Look.pv-h;
                        mode: root.preview-mode;
                        anim: Look.anim;
                        anim-speed: Look.anim-speed;
                        heard: Look.heard;
                        levels: Look.levels;
                        loader-colors: Look.loader-colors;
                        error-text: "No model selected";
                        pill-bg: Look.pill-bg;
                        pill-opacity: Look.pill-opacity;
                        idle-color: Look.idle-color;
                        eq-colors: Look.eq-colors;
                        ok-color: Look.ok-color;
                        danger-color: Look.danger-color;
                        r-tl: Look.r-tl;
                        r-tr: Look.r-tr;
                        r-br: Look.r-br;
                        r-bl: Look.r-bl;
                        pill-border-width: Look.pill-border-width;
                        pill-border-color: Look.pill-border-color;
                        bar-width: Look.bar-width;
                        bar-spacing: Look.bar-spacing;
                        bar-radius: Look.bar-radius;
                        bar-fade: Look.bar-fade;
                    }
                }
                // state selector chips — they scope the controls below
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    height: 30px;
                    for m in ["eq", "loader", "done", "error"]: Rectangle {
                        width: t.preferred-width + 20px;
                        border-radius: Theme.radius;
                        background: root.preview-mode == m ? Theme.pal.accent : Theme.pal.control;
                        border-width: 1px;
                        border-color: root.preview-mode == m ? transparent : Theme.pal.border;
                        t := Text {
                            text: m == "eq" ? "Recording" : m == "loader" ? "Transcribing" : m == "done" ? "Done" : "Error";
                            color: root.preview-mode == m ? Theme.pal.accent-fg : Theme.pal.fg;
                            font-size: 12px;
                            font-weight: 600;
                        }
                        TouchArea {
                            clicked => {
                                root.preview-mode = m;
                                root.state-picked(m);
                            }
                            mouse-cursor: MouseCursor.pointer;
                        }
                    }
                }
                Row {
                    label: "Show indicator on screen";
                    hint: "Pins the real indicator on screen so you can see every edit live.";
                    Toggle {
                        checked: root.pin-indicator;
                        toggled(v) => {
                            root.pin-indicator = v;
                            root.pin-overlay(v);
                        }
                    }
                }

                SectionTitle { text: "PILL"; }
                Row {
                    label: "Indicator theme";
                    hint: "Color preset for the pill. Any edit becomes an unsaved custom theme you can save.";
                    Select {
                        options: root.theme-names;
                        current <=> root.theme-current;
                        changed(i) => { root.theme-picked(i); }
                    }
                }
                if cfg.theme-dirty || cfg.theme-is-custom: Row {
                    label: cfg.theme-is-custom ? "Custom theme" : "Save theme as";
                    tname := Field {
                        text: cfg.theme-custom-name;
                        placeholder: "my-theme";
                    }
                    Btn {
                        text: cfg.theme-is-custom ? "Update" : "Save";
                        primary: true;
                        clicked => { root.save-theme(tname.text); }
                    }
                    if cfg.theme-is-custom: Btn {
                        text: "Delete";
                        danger: true;
                        clicked => { root.delete-theme(); }
                    }
                }
                Row {
                    label: "Position";
                    hint: "Where the pill sits on screen. \"custom\" unlocks exact X/Y coordinates.";
                    Select {
                        options: root.positions;
                        current: cfg.window-position == "bottom_left" ? 1
                            : cfg.window-position == "bottom_right" ? 2
                            : cfg.window-position == "top_center" ? 3
                            : cfg.window-position == "top_left" ? 4
                            : cfg.window-position == "top_right" ? 5
                            : cfg.window-position == "custom" ? 6 : 0;
                        changed(i) => { root.set-str("window_position", root.positions[i]); }
                    }
                }
                if cfg.window-position == "custom": Row {
                    label: "Custom X / Y";
                    hint: "Pixel offsets from the screen's top-left corner.";
                    Field { text: cfg.overlay-x; placeholder: "0"; submitted(v) => { root.set-str("overlay_x", v); } }
                    Field { text: cfg.overlay-y; placeholder: "0"; submitted(v) => { root.set-str("overlay_y", v); } }
                }
                Row {
                    label: "Size (W × H)";
                    hint: "Pill width and height in pixels.";
                    SliderX { value: cfg.overlay-width; minimum: 140; maximum: 480; step: 2; changed(v) => { root.set-num("overlay_width", v); } }
                    SliderX { value: cfg.overlay-height; minimum: 36; maximum: 120; step: 2; changed(v) => { root.set-num("overlay_height", v); } }
                    Text { text: "\{Math.round(cfg.overlay-width)}×\{Math.round(cfg.overlay-height)}"; color: Theme.pal.muted; font-size: 12px; vertical-alignment: center; }
                }
                Row {
                    label: "Opacity";
                    hint: "Pill background transparency (bars stay fully visible).";
                    SliderX {
                        value: cfg.overlay-opacity;
                        minimum: 0.5;
                        maximum: 1.0;
                        step: 0.02;
                        changed(v) => { root.set-num("overlay_opacity", v); }
                    }
                }
                Row {
                    label: "Link corners";
                    hint: "One radius for all four corners — unlink to shape each corner separately.";
                    Toggle { checked: cfg.corner-link; toggled(v) => { root.set-bool("corner_link", v); } }
                    if cfg.corner-link: SliderX {
                        value: cfg.corner-radius;
                        minimum: -1;
                        maximum: 40;
                        step: 1;
                        changed(v) => { root.set-num("corner_radius", v); }
                    }
                    if cfg.corner-link: Text {
                        text: cfg.corner-radius < 0 ? "theme" : "\{Math.round(cfg.corner-radius)}px";
                        color: Theme.pal.muted;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
                if !cfg.corner-link: Row {
                    label: "Top corners (L/R)";
                    hint: "Top-left and top-right corner radius, in pixels.";
                    SliderX { value: cfg.c-tl; minimum: 0; maximum: 40; step: 1; changed(v) => { root.set-corner(0, v); } }
                    SliderX { value: cfg.c-tr; minimum: 0; maximum: 40; step: 1; changed(v) => { root.set-corner(1, v); } }
                }
                if !cfg.corner-link: Row {
                    label: "Bottom corners (L/R)";
                    hint: "Bottom-left and bottom-right corner radius, in pixels.";
                    SliderX { value: cfg.c-bl; minimum: 0; maximum: 40; step: 1; changed(v) => { root.set-corner(3, v); } }
                    SliderX { value: cfg.c-br; minimum: 0; maximum: 40; step: 1; changed(v) => { root.set-corner(2, v); } }
                }
                Row {
                    label: "Background";
                    hint: "Pill background and accent color overrides. \"theme\" follows the preset.";
                    ColorField {
                        value: cfg.overlay-bg-value;
                        cleared: cfg.overlay-bg == "";
                        picked(c) => { root.pillbg-picked(c); }
                        clear => { root.pillbg-clear(); }
                    }
                    Text { text: "Accent"; color: Theme.pal.fg; font-size: 13px; vertical-alignment: center; }
                    ColorField {
                        value: cfg.accent-value;
                        cleared: cfg.accent-color == "";
                        picked(c) => { root.accent-picked(c); }
                        clear => { root.accent-clear(); }
                    }
                }
                Row {
                    label: "Border / width";
                    hint: "Outline drawn around the pill; width 0 hides it.";
                    ColorField {
                        value: cfg.border-value;
                        cleared: cfg.border-color == "";
                        picked(c) => { root.border-picked(c); }
                        clear => { root.border-clear(); }
                    }
                    SliderX { value: cfg.border-width; minimum: 0; maximum: 6; step: 1; changed(v) => { root.set-num("border_width", v); } }
                }

                // ── per-state sections ────────────────────────────────
                if root.preview-mode == "eq": VerticalLayout {
                    spacing: 6px;
                    SectionTitle { text: "RECORDING — BARS"; }
                    Row {
                        label: "Bar count";
                    hint: "How many equalizer bars the pill renders.";
                        SliderX { value: cfg.bar-count; minimum: 8; maximum: 48; step: 1; changed(v) => { root.set-num("bar_count", v); } }
                        Text { text: "\{Math.round(cfg.bar-count)}"; color: Theme.pal.muted; font-size: 12px; vertical-alignment: center; }
                    }
                    Row {
                        label: "Width / gap";
                    hint: "Bar thickness and spacing in pixels; -1 sizes them automatically.";
                        SliderX { value: cfg.bar-width; minimum: -1; maximum: 16; step: 1; changed(v) => { root.set-num("bar_width", v); } }
                        SliderX { value: cfg.bar-spacing; minimum: -1; maximum: 16; step: 1; changed(v) => { root.set-num("bar_spacing", v); } }
                    }
                    Row {
                        label: "Bar rounding";
                    hint: "Rounds the bar caps.";
                        SliderX { value: cfg.bar-radius; minimum: 0; maximum: 16; step: 1; changed(v) => { root.set-num("bar_radius", v); } }
                    }
                    Row {
                        label: "Quiet bars fade";
                    hint: "Quiet bars turn translucent instead of staying solid.";
                        Toggle { checked: cfg.bar-fade; toggled(v) => { root.set-bool("bar_fade", v); } }
                    }
                    SectionTitle { text: "RECORDING — GRADIENT"; }
                    GradientEditor {
                        stops: Look.eq-colors;
                        stop-picked(i, c) => { root.eq-set(i, c); }
                        stop-removed(i) => { root.eq-remove(i); }
                        stop-added => { root.eq-add(); }
                    }
                }

                if root.preview-mode == "loader": VerticalLayout {
                    spacing: 6px;
                    SectionTitle { text: "TRANSCRIBING"; }
                    Row {
                        label: "Animation";
                    hint: "The pattern shown while your speech is transcribed.";
                        Select {
                            options: ["waves (classic)", "sweep", "pulse", "dots"];
                            current: cfg.transcribe-anim == "sweep" ? 1
                                : cfg.transcribe-anim == "pulse" ? 2
                                : cfg.transcribe-anim == "dots" ? 3 : 0;
                            changed(i) => {
                                root.set-str("transcribe_anim",
                                    i == 1 ? "sweep" : i == 2 ? "pulse" : i == 3 ? "dots" : "waves");
                            }
                        }
                    }
                    Row {
                        label: "Speed";
                    hint: "Transcribing animation speed multiplier.";
                        SliderX {
                            value: cfg.anim-speed;
                            minimum: 0.25;
                            maximum: 3.0;
                            step: 0.25;
                            changed(v) => { root.set-num("anim_speed", v); }
                        }
                        Text { text: "\{cfg.anim-speed}×"; color: Theme.pal.muted; font-size: 12px; vertical-alignment: center; }
                    }
                    Row {
                        label: "Use recording colors";
                    hint: "Transcribing reuses the recording gradient. Unlink to give it its own colors.";
                        Toggle { checked: cfg.trans-link; toggled(v) => { root.set-bool("trans_link", v); } }
                    }
                    if !cfg.trans-link: VerticalLayout {
                        spacing: 6px;
                        SectionTitle { text: "TRANSCRIBING — GRADIENT"; }
                        GradientEditor {
                            stops: Look.loader-colors;
                            stop-picked(i, c) => { root.trans-set(i, c); }
                            stop-removed(i) => { root.trans-remove(i); }
                            stop-added => { root.trans-add(); }
                        }
                    }
                }

                if root.preview-mode == "done": VerticalLayout {
                    spacing: 6px;
                    SectionTitle { text: "DONE"; }
                    Row {
                        label: "Check color";
                    hint: "Color of the ✓ shown when text is delivered.";
                        ColorField {
                            value: cfg.done-value;
                            cleared: cfg.done-color == "";
                            picked(c) => { root.done-picked(c); }
                            clear => { root.done-clear(); }
                        }
                    }
                }

                if root.preview-mode == "error": VerticalLayout {
                    spacing: 6px;
                    SectionTitle { text: "ERROR"; }
                    Row {
                        label: "Flash color";
                    hint: "Background flash color when something goes wrong.";
                        ColorField {
                            value: cfg.error-value;
                            cleared: cfg.error-color == "";
                            picked(c) => { root.error-picked(c); }
                            clear => { root.error-clear(); }
                        }
                    }
                }
            }
        }
    }
}
