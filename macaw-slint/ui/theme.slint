// Palette plumbing. Rust owns the theme table (ported from the old ui/src/
// theme.ts) and pushes a resolved Palette — theme defaults merged with the
// user's config overrides — into this global whenever config changes.

export struct Palette {
    bg: color,
    surface: color,
    control: color,
    fg: color,
    muted: color,
    border: color,
    accent: color,
    accent-fg: color,
    ok: color,
    warn: color,
    danger: color,
    overlay-bg: color,
    eq-idle: color,
}

export global Theme {
    // macaw palette as compile-time default; Rust replaces it on startup.
    in-out property <Palette> pal: {
        bg: #FDF4EA,
        surface: #FFFFFF,
        control: #FBF1E4,
        fg: #1B1712,
        muted: #8A7C6C,
        border: #EADBC7,
        accent: #E5322B,
        accent-fg: #FFFFFF,
        ok: #2E9E6B,
        warn: #B8860B,
        danger: #C81F1A,
        overlay-bg: #171310,
        eq-idle: #E7D8C4,
    };
    in-out property <length> radius: 0px;
    // toggled by Rust on every theme swap: a full-window rect bound to it
    // (app.slint) forces whole-window damage — the partial software renderer
    // otherwise leaves stale regions (header) after a mass palette change.
    in-out property <bool> repaint-flip: false;
}

// Resolved overlay look (theme + config overrides merged by Rust) shared by
// the settings live preview and the theming editors. The real overlay window
// is a separate component tree and receives the same values as properties.
export global Look {
    in-out property <color> pill-bg: #171310;
    in-out property <float> pill-opacity: 0.94;
    in-out property <color> idle-color: #E7D8C4;
    in-out property <[color]> eq-colors: [#E5322B, #F7B500, #2F6FD0];
    in-out property <color> ok-color: #2E9E6B;
    in-out property <color> danger-color: #C81F1A;
    in-out property <length> r-tl: 18px;
    in-out property <length> r-tr: 18px;
    in-out property <length> r-br: 18px;
    in-out property <length> r-bl: 3px;
    in-out property <length> pill-border-width: 0px;
    in-out property <color> pill-border-color: transparent;
    in-out property <float> bar-width: -1;
    in-out property <float> bar-spacing: -1;
    in-out property <length> bar-radius: 0px;
    in-out property <bool> bar-fade: true;
    in-out property <string> anim: "waves";
    in-out property <float> anim-speed: 1.0;
    in-out property <[color]> loader-colors: [#E5322B, #F7B500, #2F6FD0];
    in-out property <float> heard: 0;
    in-out property <length> pv-w: 210px;
    in-out property <length> pv-h: 52px;
    in-out property <[float]> levels;
}
