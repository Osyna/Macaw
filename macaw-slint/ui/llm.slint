// LLM formatting tab: enable the post-STT formatter, pick a model (small local
// via llama.cpp, or a configured cloud provider), customise the system prompt
// (blank = smart mode), and try it on a sample. Two columns so it fits the
// fixed window height: left = switch + model, right = prompt + try-it.

import { Theme } from "theme.slint";
import { Btn, Badge, Toggle, Select, Field, MultiField, ProgressBar, Card, Row, ScrollArea } from "widgets.slint";
import { Cfg } from "settings.slint";

export struct LlmModelRow {
    id: string,
    label: string,
    backend: string,
    size: string,
    speed: string,
    cloud: bool,
    recommended: bool,
    desc: string,        // compact one-line description
    notes: string,
    rating: int,
    source-url: string,
    repo-url: string,
    available: bool,     // runtime (venv) installed
    installed: bool,     // weights on disk
    ready: bool,         // can format right now
    active: bool,
    api-key-set: bool,
    provider: bool,      // a configured cloud provider (vs a catalog model)
    busy: bool,
    progress-pct: float, // -1 = indeterminate
    progress-msg: string,
}

export component LlmView inherits ScrollArea {
    in property <Cfg> cfg;
    in property <[LlmModelRow]> models;
    in property <[string]> names;      // dropdown labels (index-paired with models)
    in property <int> current;         // active model index (-1 = none)
    in property <LlmModelRow> sel;      // the active/selected model's detail
    in property <bool> have-sel;
    in property <string> test-output;
    in property <bool> test-busy;
    in property <string> default-prompt; // built-in smart prompt (shown when custom is blank)
    in property <bool> op-running;

    callback set-bool(string, bool);
    callback set-str(string, string);
    callback activate(string);   // model id
    callback install(string);    // pip extra
    callback download(string);   // model id
    callback delete(string);     // model id
    callback cancel();
    callback run-test(string);
    callback open-url(string);
    callback manage-providers();

    viewport-height: cols.preferred-height;

    cols := HorizontalLayout {
        width: root.content-width;
        padding: 16px;
        spacing: 14px;

        // ── left: switch + model ─────────────────────────────────────
        VerticalLayout {
            width: (root.content-width - 46px) * 0.5;
            alignment: start;
            spacing: 14px;

            Card {
                title: "FORMATTING";
                Row {
                    label: "Enable";
                    hint: "Pass the finished transcription through an LLM that fixes punctuation, trims dictation filler and formats the text. Applies to Clipboard and Type output — live typing streams words as you speak, so it's left untouched.";
                    Toggle {
                        checked: cfg.llm-enabled;
                        toggled(v) => { root.set-bool("llm_enabled", v); }
                    }
                }
                Text {
                    text: "Smart mode reads what you dictated — an email, a chat reply, a list — and shapes it to match, without changing your words or answering the content.";
                    color: Theme.pal.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }

            Card {
                title: "MODEL";
                HorizontalLayout {
                    spacing: 8px;
                    Select {
                        width: 240px;
                        options: root.names;
                        current: root.current;
                        changed(i) => {
                            if (i >= 0 && i < root.models.length) {
                                root.activate(root.models[i].id);
                            }
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Btn {
                        text: "Providers →";
                        clicked => { root.manage-providers(); }
                    }
                }

                if !root.have-sel: Text {
                    text: "Pick a formatter model, or add a cloud provider.";
                    color: Theme.pal.muted;
                    font-size: 12px;
                }

                if root.have-sel: Rectangle {
                    border-radius: Theme.radius;
                    background: Theme.pal.control;
                    border-width: 1px;
                    border-color: sel.ready ? Theme.pal.ok : Theme.pal.border;
                    VerticalLayout {
                        padding: 14px;
                        spacing: 8px;
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            Text {
                                text: sel.label;
                                color: Theme.pal.fg;
                                font-size: 14px;
                                font-weight: 800;
                                vertical-alignment: center;
                            }
                            if sel.provider: Badge { text: "PROVIDER"; tint: Theme.pal.accent; }
                            if sel.cloud && !sel.provider: Badge { text: "CLOUD"; tint: Theme.pal.warn; }
                            if !sel.cloud: Badge { text: sel.size; }
                            if sel.ready: Badge { text: "READY"; tint: Theme.pal.ok; }
                            if sel.recommended: Badge { text: "REC"; tint: Theme.pal.ok; }
                            Rectangle { horizontal-stretch: 1; }
                            Text {
                                text: sel.speed;
                                color: Theme.pal.muted;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                        if sel.desc != "": Text {
                            text: sel.desc;
                            color: Theme.pal.muted;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                        if sel.busy: VerticalLayout {
                            spacing: 4px;
                            ProgressBar { pct: sel.progress-pct; }
                            HorizontalLayout {
                                Text {
                                    text: sel.progress-msg;
                                    color: Theme.pal.muted;
                                    font-size: 11px;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                Btn { text: "Cancel"; clicked => { root.cancel(); } }
                            }
                        }
                        if !sel.busy: HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            if !sel.cloud && !sel.available: Btn {
                                text: "Install runtime";
                                primary: true;
                                enabled: !root.op-running;
                                clicked => { root.install("llm"); }
                            }
                            if !sel.cloud && sel.available && !sel.installed: Btn {
                                text: "Download " + sel.size;
                                primary: true;
                                enabled: !root.op-running;
                                clicked => { root.download(sel.id); }
                            }
                            if sel.cloud && !sel.api-key-set: Btn {
                                text: "Set up →";
                                primary: true;
                                clicked => { root.manage-providers(); }
                            }
                            if !sel.cloud && sel.installed: Btn {
                                text: "Delete";
                                danger: true;
                                enabled: !root.op-running;
                                clicked => { root.delete(sel.id); }
                            }
                            if sel.source-url != "": Btn {
                                text: "About ↗";
                                clicked => { root.open-url(sel.source-url); }
                            }
                        }
                    }
                }
            }
        }

        // ── right: prompt + try-it ───────────────────────────────────
        VerticalLayout {
            width: (root.content-width - 46px) * 0.5;
            alignment: start;
            spacing: 14px;

            Card {
                title: "SYSTEM PROMPT";
                Text {
                    text: cfg.llm-prompt == ""
                        ? "The built-in smart prompt (below) is used. Edit it and Save to customise."
                        : "Custom prompt — sent with every format.";
                    color: cfg.llm-prompt == "" ? Theme.pal.muted : Theme.pal.accent;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                prompt-ed := MultiField {
                    min-height: 150px;
                    text: cfg.llm-prompt != "" ? cfg.llm-prompt : root.default-prompt;
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;
                    Btn {
                        text: "Reset to smart mode";
                        enabled: cfg.llm-prompt != "";
                        clicked => { root.set-str("llm_prompt", ""); }
                    }
                    Btn {
                        text: "Save prompt";
                        primary: true;
                        clicked => { root.set-str("llm_prompt", prompt-ed.text); }
                    }
                }
            }

            Card {
                title: "TRY IT";
                Text {
                    text: "Format a sample with the current model and prompt.";
                    color: Theme.pal.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                test-in := Field {
                    text: "hey so um can you send me that report by friday thanks";
                    submitted(v) => { root.run-test(v); }
                }
                HorizontalLayout {
                    alignment: start;
                    spacing: 8px;
                    Btn {
                        text: root.test-busy ? "Formatting…" : "Format sample";
                        primary: true;
                        enabled: sel.ready && !root.test-busy;
                        clicked => { root.run-test(test-in.text); }
                    }
                    if !sel.ready: Text {
                        text: "Select a ready model first.";
                        color: Theme.pal.muted;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    height: max(56px, out-t.preferred-height + 20px);
                    border-radius: Theme.radius;
                    background: Theme.pal.bg;
                    border-width: 1px;
                    border-color: Theme.pal.border;
                    out-t := Text {
                        x: 12px;
                        y: 10px;
                        width: parent.width - 24px;
                        text: root.test-output != "" ? root.test-output : "The formatted result appears here.";
                        color: root.test-output != "" ? Theme.pal.fg : Theme.pal.muted;
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
