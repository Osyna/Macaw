// Main window: header (brand, tabs, engine dot) over Settings/Appearance/
// Models views, with a transient toast stack in the corner.

// Embedded fonts: text rendering must never depend on system-font
// enumeration — fontique's dwrite path can come up empty (observed on
// Windows/wine: fallback query unwraps None -> the app dies before the
// first window). DejaVu also guarantees the chip/status glyph coverage.
import "fonts/DejaVuSans.ttf";
import "fonts/DejaVuSans-Bold.ttf";
import "fonts/DejaVuSansMono.ttf";
import "fonts/DejaVuSansMono-Bold.ttf";

import { Theme, Palette, Look, Tip } from "theme.slint";
import { Btn, Badge, Toggle } from "widgets.slint";
import { SettingsView, Cfg } from "settings.slint";
import { AppearanceView } from "appearance.slint";
import { ModelsView, ModelRow, ParamRow } from "models.slint";
import { LlmView, LlmModelRow, PromptWindow } from "llm.slint";
import { ProvidersWindow, ProviderRow } from "providers.slint";
import { OverlayWindow } from "overlay.slint";
import { OnboardingWizard } from "onboarding.slint";
import { EasyView } from "easy.slint";

export { OverlayWindow, Cfg, ModelRow, ParamRow, LlmModelRow, ProviderRow, Palette, Theme, Look, Tip }

export struct Toast {
    level: string, // info | error | success
    msg: string,
}

component TabBtn inherits Rectangle {
    in property <string> text;
    in property <string> icon;
    in property <bool> active;
    callback clicked;
    width: row.preferred-width + 28px;
    height: 32px;
    border-radius: Theme.radius;
    background: root.active ? Theme.pal.surface : (touch.has-hover ? Theme.pal.surface.with-alpha(0.5) : transparent);
    border-width: root.active ? 1px : 0px;
    border-color: Theme.pal.border;
    row := HorizontalLayout {
        spacing: 6px;
        alignment: center;
        if root.icon != "": Text {
            text: root.icon;
            color: root.active ? Theme.pal.accent : Theme.pal.muted;
            font-size: 13px;
            vertical-alignment: center;
        }
        Text {
            text: root.text;
            color: root.active ? Theme.pal.fg : Theme.pal.muted;
            font-size: 13px;
            font-weight: root.active ? 700 : 500;
            vertical-alignment: center;
        }
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
        mouse-cursor: MouseCursor.pointer;
    }
}

export component MainWindow inherits Window {
    title: "Macaw";
    default-font-family: "DejaVu Sans Mono"; // terminal chrome (embedded); the pill keeps the UI font
    // fixed: Slint derives min=max size hints from this, so the window is
    // not resizable; a Hyprland rule (main.rs) floats it so it never tiles
    width: 1180px;
    height: 760px;
    background: Theme.pal.bg;

    in-out property <string> tab: "models"; // models | appearance | settings
    changed tab => { root.tab-changed(self.tab); }
    callback tab-changed(string);
    in property <float> mic-level: 0;
    in-out property <bool> show-about: false;
    in property <string> app-version: "";
    callback restart-engine();
    callback reload-model();
    in property <bool> engine-connected: false;
    in property <string> engine-state: "idle";
    in property <string> formatter-label: "";
    in property <string> formatter-status: "";
    in property <bool> formatter-ok: false;
    callback reload-formatter();
    callback restart-formatter();
    in property <string> active-model-label: "";
    in property <[Toast]> toasts;

    // settings plumbing (forwarded)
    in property <Cfg> cfg;
    in property <[string]> devices;
    in-out property <int> device-current;
    in property <bool> capturing-hotkey;
    in property <bool> live-native: false;
    // Rust-gated (not cfg.onboarded directly): stays false until a REAL
    // config arrives, so existing users never see a wizard flash at boot.
    in property <bool> show-wizard: false;
    callback set-str(string, string);
    callback set-num(string, float);
    callback set-bool(string, bool);
    callback pick-device(int);
    callback capture-hotkey();
    callback set-autostart(bool);
    // providers plumbing (forwarded)
    in property <[ProviderRow]> providers;
    in property <ProviderRow> provider-sel;
    in property <int> provider-sel-index;
    in property <string> provider-test-result;
    in property <bool> provider-testing;
    callback provider-select(int);
    callback provider-set-enabled(string, bool);
    callback provider-save-config(string, string, string);
    callback provider-save-key(string, string);
    callback provider-clear-key(string);
    callback provider-test(string);
    callback provider-use(string);
    callback eq-set(int, color);
    callback eq-add();
    callback eq-remove(int);
    callback set-corner(int, float);
    callback pillbg-picked(color);
    callback pillbg-clear();
    in-out property <bool> pin-indicator: false;
    in-out property <string> preview-mode: "eq";
    callback pin-overlay(bool);
    callback state-picked(string);
    callback accent-picked(color);
    callback accent-clear();
    callback border-picked(color);
    callback border-clear();
    in property <[string]> theme-names;
    in-out property <int> theme-current;
    callback theme-picked(int);
    callback save-theme(string);
    callback delete-theme();
    callback trans-set(int, color);
    callback trans-add();
    callback trans-remove(int);
    callback done-picked(color);
    callback done-clear();
    callback donering-picked(color);
    callback donering-clear();
    callback error-picked(color);
    callback error-clear();
    // models plumbing (forwarded)
    in property <[ModelRow]> models;
    in property <bool> models-loading;
    in property <ModelRow> sel;
    in property <bool> have-sel;
    in property <bool> op-running;
    in property <[ParamRow]> detail-params;
    in property <[string]> langs;
    in property <int> lang-current;
    in property <int> default-lang-current;
    in property <string> hw-summary;
    callback pick-default-lang(int);
    callback install(string);
    callback download(string);
    callback activate(string);
    callback delete(string);
    callback cancel-op();
    callback toggle-expand(string);
    callback open-url(string);
    callback set-lang(string, int);
    callback param-num(string, string, float);
    callback param-bool(string, string, bool);
    callback models-search(string);
    callback models-filter(int);
    // llm plumbing (forwarded)
    in property <[LlmModelRow]> llm-models;
    in property <bool> llm-loading;
    in property <[string]> llm-names;
    in property <int> llm-current;
    in property <LlmModelRow> llm-sel;
    in property <bool> llm-have-sel;
    in property <string> llm-test-output;
    in property <bool> llm-test-busy;
    in property <string> llm-test-stat;
    in property <string> llm-default-prompt;
    in-out property <bool> show-providers;
    in-out property <bool> show-prompt: false;
    in property <[ParamRow]> llm-detail-params;
    callback llm-param-num(string, string, float);
    callback llm-param-bool(string, string, bool);
    callback llm-activate(string);
    callback llm-install(string);
    callback llm-download(string);
    callback llm-delete(string);
    callback llm-cancel();
    callback llm-test(string);
    callback manage-providers();

    callback toggle-recording();
    callback close-window();

    // full-window damage trigger (see Theme.repaint-flip)
    Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.repaint-flip ? #00000000 : #FFFFFF00;
    }

    VerticalLayout {
        // ── header ──────────────────────────────────────────────────
        Rectangle {
            height: 56px;
            background: Theme.pal.bg;
            HorizontalLayout {
                x: 20px;
                width: parent.width - 40px;
                spacing: 10px;
                brand := Rectangle {
                    width: brand-row.preferred-width;
                    brand-row := HorizontalLayout {
                        spacing: 8px;
                        Image {
                            source: @image-url("assets/parrot.png");
                            width: 30px;
                            height: 30px;
                            y: parent.height / 2 - 15px;
                        }
                        Text {
                            text: "Macaw";
                            color: Theme.pal.accent;
                            font-size: 20px;
                            font-weight: 800;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        clicked => { root.show-about = true; }
                        mouse-cursor: MouseCursor.pointer;
                    }
                }
                Rectangle { width: 12px; }
                if root.cfg.advanced: TabBtn {
                    y: 12px;
                    icon: "◆";
                    text: "Voice Models";
                    active: root.tab == "models";
                    clicked => { root.tab = "models"; }
                }
                if root.cfg.advanced: TabBtn {
                    y: 12px;
                    icon: "◐";
                    text: "Appearance";
                    active: root.tab == "appearance";
                    clicked => { root.tab = "appearance"; }
                }
                if root.cfg.advanced: TabBtn {
                    y: 12px;
                    icon: "✦";
                    text: "Formatting";
                    active: root.tab == "llm";
                    clicked => { root.tab = "llm"; }
                }
                Rectangle { horizontal-stretch: 1; }
                if root.cfg.advanced: TabBtn {
                    y: 12px;
                    icon: "⚙";
                    text: "Settings";
                    active: root.tab == "settings";
                    clicked => { root.tab = "settings"; }
                }
                Rectangle { // Easy / Advanced mode switch — always visible
                    y: 17px;
                    height: 22px;
                    width: adv-row.preferred-width;
                    adv-row := HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Advanced";
                            color: root.cfg.advanced ? Theme.pal.accent : Theme.pal.muted;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        Toggle {
                            checked: root.cfg.advanced;
                            toggled(v) => { root.set-bool("advanced", v); }
                        }
                    }
                }
                if root.active-model-label != "" && root.cfg.advanced: Badge {
                    y: parent.height / 2 - self.height / 2;
                    text: root.active-model-label;
                    tint: Theme.pal.accent;
                }
                Rectangle { // engine status dot
                    y: parent.height / 2 - 5px;
                    width: 10px;
                    height: 10px;
                    border-radius: Theme.radius;
                    background: !root.engine-connected ? Theme.pal.danger
                        : root.engine-state == "recording" ? Theme.pal.accent
                        : root.engine-state == "error" ? Theme.pal.danger
                        : Theme.pal.ok;
                }
                Btn {
                    y: 13px;
                    text: root.engine-state == "recording" ? "Stop" : "Record";
                    primary: true;
                    enabled: root.engine-connected;
                    clicked => { root.toggle-recording(); }
                }
                Btn {
                    y: 13px;
                    text: "✕";
                    clicked => { root.close-window(); }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.pal.border; }
        }
        if !root.cfg.advanced: EasyView {
            cfg: root.cfg;
            devices: root.devices;
            device-current: root.device-current;
            langs: root.langs;
            lang-current: root.default-lang-current;
            mic-level: root.mic-level;
            engine-connected: root.engine-connected;
            engine-state: root.engine-state;
            capturing-hotkey: root.capturing-hotkey;
            set-str(k, v) => { root.set-str(k, v); }
            set-bool(k, v) => { root.set-bool(k, v); }
            pick-device(i) => { root.pick-device(i); }
            pick-default-lang(i) => { root.pick-default-lang(i); }
            capture-hotkey => { root.capture-hotkey(); }
            toggle-recording => { root.toggle-recording(); }
        }

        // ── content ─────────────────────────────────────────────────
        if root.tab == "settings" && root.cfg.advanced: SettingsView {
            cfg: root.cfg;
            devices: root.devices;
            device-current <=> root.device-current;
            langs: root.langs;
            lang-current: root.default-lang-current;
            pick-default-lang(i) => { root.pick-default-lang(i); }
            capturing-hotkey: root.capturing-hotkey;
            live-native: root.live-native;
            set-str(k, v) => { root.set-str(k, v); }
            set-num(k, v) => { root.set-num(k, v); }
            set-bool(k, v) => { root.set-bool(k, v); }
            pick-device(i) => { root.pick-device(i); }
            capture-hotkey => { root.capture-hotkey(); }
            set-autostart(v) => { root.set-autostart(v); }
            manage-providers => { root.manage-providers(); }
            mic-level: root.mic-level;
            engine-connected: root.engine-connected;
            engine-state: root.engine-state;
            restart-engine => { root.restart-engine(); }
            reload-model => { root.reload-model(); }
            formatter-label: root.formatter-label;
            formatter-status: root.formatter-status;
            formatter-ok: root.formatter-ok;
            reload-formatter => { root.reload-formatter(); }
            restart-formatter => { root.restart-formatter(); }
        }
        if root.tab == "appearance" && root.cfg.advanced: AppearanceView {
            cfg: root.cfg;
            pin-indicator <=> root.pin-indicator;
            preview-mode <=> root.preview-mode;
            set-str(k, v) => { root.set-str(k, v); }
            set-num(k, v) => { root.set-num(k, v); }
            set-bool(k, v) => { root.set-bool(k, v); }
            eq-set(i, c) => { root.eq-set(i, c); }
            eq-add => { root.eq-add(); }
            eq-remove(i) => { root.eq-remove(i); }
            set-corner(i, v) => { root.set-corner(i, v); }
            pillbg-picked(c) => { root.pillbg-picked(c); }
            pillbg-clear => { root.pillbg-clear(); }
            pin-overlay(v) => { root.pin-overlay(v); }
            state-picked(m) => { root.state-picked(m); }
            accent-picked(c) => { root.accent-picked(c); }
            accent-clear => { root.accent-clear(); }
            border-picked(c) => { root.border-picked(c); }
            border-clear => { root.border-clear(); }
            trans-set(i, c) => { root.trans-set(i, c); }
            trans-add => { root.trans-add(); }
            trans-remove(i) => { root.trans-remove(i); }
            done-picked(c) => { root.done-picked(c); }
            done-clear => { root.done-clear(); }
            donering-picked(c) => { root.donering-picked(c); }
            donering-clear => { root.donering-clear(); }
            error-picked(c) => { root.error-picked(c); }
            error-clear => { root.error-clear(); }
            theme-names: root.theme-names;
            theme-current <=> root.theme-current;
            theme-picked(i) => { root.theme-picked(i); }
            save-theme(n) => { root.save-theme(n); }
            delete-theme => { root.delete-theme(); }
        }
        if root.tab == "models" && root.cfg.advanced: ModelsView {
            models: root.models;
            loading: root.models-loading;
            sel: root.sel;
            have-sel: root.have-sel;
            op-running: root.op-running;
            detail-params: root.detail-params;
            langs: root.langs;
            lang-current: root.lang-current;
            hw-summary: root.hw-summary;
            install(e) => { root.install(e); }
            download(id) => { root.download(id); }
            activate(id) => { root.activate(id); }
            delete(id) => { root.delete(id); }
            cancel => { root.cancel-op(); }
            toggle-expand(id) => { root.toggle-expand(id); }
            open-url(u) => { root.open-url(u); }
            set-lang(id, i) => { root.set-lang(id, i); }
            param-num(id, k, v) => { root.param-num(id, k, v); }
            param-bool(id, k, v) => { root.param-bool(id, k, v); }
            search(t) => { root.models-search(t); }
            filter(i) => { root.models-filter(i); }
        }
        if root.tab == "llm" && root.cfg.advanced: LlmView {
            cfg: root.cfg;
            models: root.llm-models;
            loading: root.llm-loading;
            names: root.llm-names;
            current: root.llm-current;
            sel: root.llm-sel;
            have-sel: root.llm-have-sel;
            test-output: root.llm-test-output;
            test-busy: root.llm-test-busy;
            test-stat: root.llm-test-stat;
            default-prompt: root.llm-default-prompt;
            op-running: root.op-running;
            detail-params: root.llm-detail-params;
            set-bool(k, v) => { root.set-bool(k, v); }
            set-str(k, v) => { root.set-str(k, v); }
            activate(id) => { root.llm-activate(id); }
            install(e) => { root.llm-install(e); }
            download(id) => { root.llm-download(id); }
            delete(id) => { root.llm-delete(id); }
            cancel => { root.llm-cancel(); }
            run-test(t) => { root.llm-test(t); }
            open-url(u) => { root.open-url(u); }
            manage-providers => { root.manage-providers(); }
            param-num(i, k, v) => { root.llm-param-num(i, k, v); }
            param-bool(i, k, v) => { root.llm-param-bool(i, k, v); }
            edit-prompt => { root.show-prompt = true; }
        }
    }

    // ── toasts ──────────────────────────────────────────────────────
    VerticalLayout {
        x: parent.width - 340px;
        y: parent.height - self.preferred-height - 16px;
        width: 320px;
        spacing: 8px;
        for t in root.toasts: Rectangle {
            height: tt.preferred-height + 20px;
            border-radius: Theme.radius;
            // info follows the chrome; error/success keep semantic colors
            background: t.level == "error" ? Theme.pal.danger
                : t.level == "success" ? Theme.pal.ok : Theme.pal.surface;
            border-width: 1px;
            border-color: t.level == "error" || t.level == "success"
                ? transparent : Theme.pal.border;
            tt := Text {
                x: 12px;
                y: 10px;
                width: parent.width - 24px;
                text: t.msg;
                color: t.level == "error" || t.level == "success"
                    ? white : Theme.pal.fg;
                font-size: 12px;
                wrap: word-wrap;
            }
        }
    }

    // ── first-launch wizard (covers everything until onboarded) ─────
    if root.show-wizard: OnboardingWizard {
        width: 100%;
        height: 100%;
        cfg: root.cfg;
        devices: root.devices;
        device-current: root.device-current;
        langs: root.langs;
        lang-current: root.default-lang-current;
        mic-level: root.mic-level;
        capturing-hotkey: root.capturing-hotkey;
        live-native: root.live-native;
        set-str(k, v) => { root.set-str(k, v); }
        set-num(k, v) => { root.set-num(k, v); }
        set-bool(k, v) => { root.set-bool(k, v); }
        pick-device(i) => { root.pick-device(i); }
        pick-default-lang(i) => { root.pick-default-lang(i); }
        capture-hotkey => { root.capture-hotkey(); }
    }

    // ── cloud providers manager (opened from Settings / LLM tab) ────
    if root.show-providers: ProvidersWindow {
        width: 100%;
        height: 100%;
        providers: root.providers;
        sel: root.provider-sel;
        sel-index: root.provider-sel-index;
        test-result: root.provider-test-result;
        testing: root.provider-testing;
        cfg: root.cfg;
        select(i) => { root.provider-select(i); }
        set-enabled(id, v) => { root.provider-set-enabled(id, v); }
        save-config(id, b, m) => { root.provider-save-config(id, b, m); }
        save-key(id, k) => { root.provider-save-key(id, k); }
        clear-key(id) => { root.provider-clear-key(id); }
        test(id) => { root.provider-test(id); }
        use-provider(id) => { root.provider-use(id); }
        open-url(u) => { root.open-url(u); }
        set-str(k, v) => { root.set-str(k, v); }
        set-bool(k, v) => { root.set-bool(k, v); }
        close => { root.show-providers = false; }
    }

    // ── system-prompt editor (opened from the Formatting dossier) ───
    if root.show-prompt: PromptWindow {
        width: 100%;
        height: 100%;
        prompt: root.cfg.llm-prompt;
        default-prompt: root.llm-default-prompt;
        save(t) => { root.set-str("llm_prompt", t); }
        reset => { root.set-str("llm_prompt", ""); root.show-prompt = false; }
        close => { root.show-prompt = false; }
    }

    // ── hover hint (fed by settings rows via the Tip global) ────────
    if Tip.text != "": Rectangle {
        x: min(Tip.x, root.width - self.width - 12px);
        y: min(Tip.y, root.height - self.height - 12px);
        width: min(tip-t.preferred-width + 20px, 360px);
        height: tip-t.preferred-height + 14px;
        background: Theme.pal.control;
        border-width: 1px;
        border-color: Theme.pal.muted;
        opacity: 0;
        // subtle: fades in only after the cursor rests a moment
        states [
            shown when Tip.text != "": {
                opacity: 0.97;
                in {
                    animate opacity { duration: 120ms; delay: 350ms; }
                }
            }
        ]
        tip-t := Text {
            x: 10px;
            y: 7px;
            width: min(self.preferred-width, 340px);
            text: Tip.text;
            color: Theme.pal.fg;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    // ── about: parrot-click overlay, stacks above everything ────────
    if root.show-about: Rectangle {
        width: 100%;
        height: 100%;
        background: #000000B0;
        TouchArea { // backdrop click closes
            clicked => { root.show-about = false; }
        }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 380px;
            height: about-col.preferred-height + 56px;
            border-radius: Theme.radius;
            background: Theme.pal.surface;
            border-width: 1px;
            border-color: Theme.pal.border;
            TouchArea { } // swallow clicks inside the card
            about-col := VerticalLayout {
                x: 28px;
                y: 28px;
                width: parent.width - 56px;
                spacing: 10px;
                alignment: start;
                HorizontalLayout {
                    alignment: center;
                    Image {
                        source: @image-url("assets/parrot.png");
                        width: 72px;
                        height: 72px;
                    }
                }
                Text {
                    text: "Macaw";
                    color: Theme.pal.accent;
                    font-size: 22px;
                    font-weight: 800;
                    horizontal-alignment: center;
                }
                Text {
                    text: "v" + root.app-version;
                    color: Theme.pal.muted;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Fast local speech-to-text for Linux.\nWhisper, Parakeet, Voxtral & friends — one hotkey away.";
                    color: Theme.pal.fg;
                    font-size: 12px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                Rectangle { height: 6px; }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;
                    Btn {
                        text: "GitHub ↗";
                        clicked => { root.open-url("https://github.com/Osyna/Macaw"); }
                    }
                    Btn {
                        text: "Releases ↗";
                        clicked => { root.open-url("https://github.com/Osyna/Macaw/releases/latest"); }
                    }
                    Btn {
                        text: "osyna.com ↗";
                        clicked => { root.open-url("https://osyna.com"); }
                    }
                }
                HorizontalLayout {
                    alignment: center;
                    Btn {
                        text: "Close";
                        primary: true;
                        clicked => { root.show-about = false; }
                    }
                }
            }
        }
    }
}
