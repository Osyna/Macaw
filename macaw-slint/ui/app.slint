// Main window: header (brand, tabs, engine dot) over Settings/Models views,
// with a transient toast stack in the corner.

import { Theme, Palette, Look } from "theme.slint";
import { Btn, Badge } from "widgets.slint";
import { SettingsView, Cfg } from "settings.slint";
import { ModelsView, ModelRow, ParamRow } from "models.slint";
import { OverlayWindow } from "overlay.slint";

export { OverlayWindow, Cfg, ModelRow, ParamRow, Palette, Theme, Look }

export struct Toast {
    level: string, // info | error | success
    msg: string,
}

component TabBtn inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked;
    width: t.preferred-width + 28px;
    height: 32px;
    border-radius: Theme.radius;
    background: root.active ? Theme.pal.surface : (touch.has-hover ? Theme.pal.surface.with-alpha(0.5) : transparent);
    border-width: root.active ? 1px : 0px;
    border-color: Theme.pal.border;
    t := Text {
        text: root.text;
        color: root.active ? Theme.pal.fg : Theme.pal.muted;
        font-size: 13px;
        font-weight: root.active ? 700 : 500;
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
        mouse-cursor: MouseCursor.pointer;
    }
}

export component MainWindow inherits Window {
    title: "Macaw";
    default-font-family: "monospace"; // terminal chrome; the pill keeps the UI font
    min-width: 760px;
    min-height: 520px;
    preferred-width: 920px;
    preferred-height: 660px;
    background: Theme.pal.bg;

    in-out property <string> tab: "settings"; // settings | models
    in property <bool> engine-connected: false;
    in property <string> engine-state: "idle";
    in property <string> active-model-label: "";
    in property <[Toast]> toasts;

    // settings plumbing (forwarded)
    in property <Cfg> cfg;
    in property <[string]> devices;
    in-out property <int> device-current;
    in property <bool> capturing-hotkey;
    callback set-str(string, string);
    callback set-num(string, float);
    callback set-bool(string, bool);
    callback pick-device(int);
    callback capture-hotkey();
    callback set-autostart(bool);
    callback set-api-key(string);
    callback eq-set(int, color);
    callback eq-add();
    callback eq-remove(int);
    callback set-corner(int, float);
    callback pillbg-picked(color);
    callback pillbg-clear();
    callback pin-overlay(bool);
    callback accent-picked(color);
    callback accent-clear();
    callback border-picked(color);
    callback border-clear();
    in property <[string]> theme-names;
    in-out property <int> theme-current;
    // models plumbing (forwarded)
    in property <[ModelRow]> models;
    in property <bool> op-running;
    in property <[ParamRow]> detail-params;
    in property <[string]> langs;
    in property <int> lang-current;
    callback install(string);
    callback download(string);
    callback activate(string);
    callback delete(string);
    callback cancel-op();
    callback toggle-expand(string);
    callback open-url(string);
    callback set-lang(string, int);
    callback param-num(string, string, float);
    callback param-bool(string, string, bool);
    callback models-search(string);
    callback models-filter(int);

    callback toggle-recording();

    // full-window damage trigger (see Theme.repaint-flip)
    Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.repaint-flip ? #00000000 : #FFFFFF00;
    }

    VerticalLayout {
        // ── header ──────────────────────────────────────────────────
        Rectangle {
            height: 56px;
            background: Theme.pal.bg;
            HorizontalLayout {
                x: 20px;
                width: parent.width - 40px;
                spacing: 10px;
                Text {
                    text: "Macaw";
                    color: Theme.pal.accent;
                    font-size: 20px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
                Rectangle { width: 12px; }
                TabBtn {
                    y: 12px;
                    text: "Settings";
                    active: root.tab == "settings";
                    clicked => { root.tab = "settings"; }
                }
                TabBtn {
                    y: 12px;
                    text: "Models";
                    active: root.tab == "models";
                    clicked => { root.tab = "models"; }
                }
                Rectangle { horizontal-stretch: 1; }
                if root.active-model-label != "": Badge {
                    y: parent.height / 2 - self.height / 2;
                    text: root.active-model-label;
                    tint: Theme.pal.accent;
                }
                Rectangle { // engine status dot
                    y: parent.height / 2 - 5px;
                    width: 10px;
                    height: 10px;
                    border-radius: Theme.radius;
                    background: !root.engine-connected ? Theme.pal.danger
                        : root.engine-state == "recording" ? Theme.pal.accent
                        : root.engine-state == "error" ? Theme.pal.danger
                        : Theme.pal.ok;
                }
                Btn {
                    y: 13px;
                    text: root.engine-state == "recording" ? "Stop" : "Record";
                    primary: true;
                    enabled: root.engine-connected;
                    clicked => { root.toggle-recording(); }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.pal.border; }
        }

        // ── content ─────────────────────────────────────────────────
        if root.tab == "settings": SettingsView {
            cfg: root.cfg;
            devices: root.devices;
            device-current <=> root.device-current;
            capturing-hotkey: root.capturing-hotkey;
            set-str(k, v) => { root.set-str(k, v); }
            set-num(k, v) => { root.set-num(k, v); }
            set-bool(k, v) => { root.set-bool(k, v); }
            pick-device(i) => { root.pick-device(i); }
            capture-hotkey => { root.capture-hotkey(); }
            set-autostart(v) => { root.set-autostart(v); }
            set-api-key(v) => { root.set-api-key(v); }
            eq-set(i, c) => { root.eq-set(i, c); }
            eq-add => { root.eq-add(); }
            eq-remove(i) => { root.eq-remove(i); }
            set-corner(i, v) => { root.set-corner(i, v); }
            pillbg-picked(c) => { root.pillbg-picked(c); }
            pillbg-clear => { root.pillbg-clear(); }
            pin-overlay(v) => { root.pin-overlay(v); }
            accent-picked(c) => { root.accent-picked(c); }
            accent-clear => { root.accent-clear(); }
            border-picked(c) => { root.border-picked(c); }
            border-clear => { root.border-clear(); }
            theme-names: root.theme-names;
            theme-current <=> root.theme-current;
        }
        if root.tab == "models": ModelsView {
            models: root.models;
            op-running: root.op-running;
            detail-params: root.detail-params;
            langs: root.langs;
            lang-current: root.lang-current;
            install(e) => { root.install(e); }
            download(id) => { root.download(id); }
            activate(id) => { root.activate(id); }
            delete(id) => { root.delete(id); }
            cancel => { root.cancel-op(); }
            toggle-expand(id) => { root.toggle-expand(id); }
            open-url(u) => { root.open-url(u); }
            set-lang(id, i) => { root.set-lang(id, i); }
            param-num(id, k, v) => { root.param-num(id, k, v); }
            param-bool(id, k, v) => { root.param-bool(id, k, v); }
            search(t) => { root.models-search(t); }
            filter(i) => { root.models-filter(i); }
        }
    }

    // ── toasts ──────────────────────────────────────────────────────
    VerticalLayout {
        x: parent.width - 340px;
        y: parent.height - self.preferred-height - 16px;
        width: 320px;
        spacing: 8px;
        for t in root.toasts: Rectangle {
            height: tt.preferred-height + 20px;
            border-radius: Theme.radius;
            background: t.level == "error" ? Theme.pal.danger
                : t.level == "success" ? Theme.pal.ok : Theme.pal.fg;
            tt := Text {
                x: 12px;
                y: 10px;
                width: parent.width - 24px;
                text: t.msg;
                color: white;
                font-size: 12px;
                wrap: word-wrap;
            }
        }
    }
}
