{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Macaw",
  "version": "0.4.3",
  "identifier": "com.osyna.macaw",
  "build": {
    "beforeDevCommand": "cd ../ui && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ../ui && bun install && bun run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Macaw",
        "width": 900,
        "height": 640,
        "resizable": true,
        "visible": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "Macaw Overlay",
        "width": 210,
        "height": 52,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "focusable": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/macaw-engine"],
    "resources": ["resources/*"],
    "linux": {
      "deb": {
        "depends": ["libgtk-layer-shell0"]
      },
      "rpm": {
        "depends": ["gtk-layer-shell"]
      }
    }
  }
}
